function displayBISEntries() {
  console.log('=== BUILDING INFO SYSTEM (BIS) ENTRIES ===');
  const allBuildings = BIS.getAllBuildings();
  
  allBuildings.forEach(building => {
    console.log(`\n🏗️ ${building.name}`);
    console.log(`  NW Coordinate: (${building.nwCoordinate.x}, ${building.nwCoordinate.y})`);
    console.log(`  Dimensions: ${building.dimensions.width}ft × ${building.dimensions.length}ft`);
    console.log(`  Height: ${building.height}ft`);
    console.log(`  Color: ${building.color}`);
    console.log(`  Position: (${building.position.x0}, ${building.position.y0}) to (${building.position.x1}, ${building.position.y1})`);
    console.log(`  Source: user`);
    
    if (building.sections) {
      console.log(`  Sections (${building.sections.length}):`);
      building.sections.forEach(section => {
        console.log(`    ${section.name}: ${section.height}ft, ${section.color}`);
