    jsCode += `    rotation: ${data.rotation},\n`;
    jsCode += `    x: ${data.x},\n`;
    jsCode += `    y: ${data.y},\n`;
    jsCode += `    opacity: ${data.opacity}\n`;
    jsCode += `  },\n`;
  });
  
  jsCode += '};\n\n';
  jsCode += '// Function to initialize map defaults\n';
  jsCode += 'function initializeMapDefaults() {\n';
  jsCode += '  Object.entries(MAP_DEFAULT_POSITIONS).forEach(([index, position]) => {\n';
  jsCode += '    const storageKey = \'plateH_map\' + index + \'_settings\';\n';
  jsCode += '    localStorage.setItem(storageKey, JSON.stringify({\n';
  jsCode += '      scale: position.scale,\n';
  jsCode += '      rotation: position.rotation,\n';
  jsCode += '      x: position.x,\n';
  jsCode += '      y: position.y,\n';
  jsCode += '      opacity: position.opacity\n';
  jsCode += '    }));\n';
  jsCode += '  });\n';
  jsCode += '}\n';
  
  console.log('=== GITHUB-READY JAVASCRIPT CODE ===');
  console.log('Copy this code and paste into GitHub version:');
  console.log(jsCode);
  console.log('==========================================');
  
  // Create downloadable file
  const blob = new Blob([jsCode], { type: 'text/javascript' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'map-positions-github.js';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  
  console.log('📁 Downloaded map-positions-github.js file');
  
  return jsCode;
};

