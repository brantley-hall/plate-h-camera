<span style="display:none" id="ps-nwpos"></span>



</div><!-- end wrapper -->
<script>
// ── Canvases ──────────────────────────────────────────────────────────────
const plan       = document.getElementById('plan');
const pctx       = plan.getContext('2d');
// const zoom       = document.getElementById('zoom');
// const zctx       = zoom.getContext('2d');


// ── Constants ─────────────────────────────────────────────────────────────
let churchDistance=777; // Initial value, will be controlled by slider
const GAP=churchDistance;
const MARGIN_LEFT_FT=220;

// ── Grid System Constants ─────────────────────────────────────────────────
const GRID_TOTAL_WIDTH_FT = 1300;  // Total grid width in feet
const GRID_X_MIN = -300;             // Minimum X coordinate (feet)
const GRID_X_MAX = 1000;             // Maximum X coordinate (feet)
const GRID_Y_MIN = -300;             // Minimum Y coordinate (feet) 
const GRID_Y_MAX = 300;              // Maximum Y coordinate (feet)
const GRID_WIDTH_FT = GRID_X_MAX - GRID_X_MIN;  // 1300 feet
const GRID_HEIGHT_FT = GRID_Y_MAX - GRID_Y_MIN; // 600 feet

// ── Road System Constants ─────────────────────────────────────────────────
const ROAD_WIDTH_FT = 40;           // Standard road width in feet
const ROAD_HEIGHT_FT = 2.0;         // Roads are flat surfaces with visible height
const ROAD_COLOR = 'rgba(80,80,80,0.8)';  // Gray road color
const ROAD_LINE_COLOR = 'rgba(255,255,255,0.3)'; // White lane markings


// ── Hard-Coded Road Segments (four-corner definition) ───────────────
const roadSegments = [
  // Washington Square East - 50 ft wide road along Y-axis, extends to south extent, bounded by Y-axis on right, moved up 30 ft
  {
    name: "Washington Square East",
    corners: [
      {x: -50, y: 30},     // Southwest corner (moved up 30 ft)
      {x: 0, y: 30},       // Southeast corner (bounded by Y-axis, moved up 30 ft)
      {x: 0, y: -300},     // Northeast corner (extends to south extent, moved up 30 ft)
      {x: -50, y: -300}    // Northwest corner (extends to south extent, moved up 30 ft)
    ],
    color: 'rgba(205,133,63,0.8)',  // Clay-colored roadways
    height: ROAD_HEIGHT_FT,  // Add height property for ray-casting
    showLabel: true,
    labelRotation: 270  // Rotated 180 degrees (90 + 180)
  },
  // University Place - 75 ft wide road moved 75 ft east, going northward
  {
    name: "University Place",
    corners: [
      {x: -50, y: 0},      // Southwest corner (moved 75 ft east)
      {x: 25, y: 0},       // Southeast corner (moved 75 ft east)
      {x: 25, y: 300},     // Northeast corner (extends northward)
      {x: -50, y: 300}     // Northwest corner (moved 75 ft east)
    ],
    color: 'rgba(205,133,63,0.8)',  // Clay-colored roadways
    height: ROAD_HEIGHT_FT,  // Add height property for ray-casting
    showLabel: true,
    labelRotation: 270  // Match Mercer Street orientation
  },
  // Waverly Place - 60 ft wide road running east along x-axis from origin for 702 ft, moved 30 ft north
  {
    name: "Waverly Place",
    corners: [
      {x: 0, y: 0},        // Southwest corner (moved 30 ft north)
      {x: 702, y: 0},      // Southeast corner (extends 702 ft east, moved 30 ft north)
      {x: 702, y: 60},     // Northeast corner (60 ft wide, moved 30 ft north)
      {x: 0, y: 60}        // Northwest corner (moved 30 ft north)
    ],
    color: 'rgba(205,133,63,0.8)',  // Clay-colored roadways
    height: ROAD_HEIGHT_FT,  // Add height property for ray-casting
    showLabel: true,
    labelRotation: 0  // No rotation for horizontal text
  },
