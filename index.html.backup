          <input type="number" id="nwx-${building.name}" value="${building.nwCoordinate.x}" 
                 style="width:45px;font-size:0.5rem;font-family:'Source Code Pro',monospace;border:1px solid var(--rule);background:var(--paper);color:var(--ink);padding:1px;"
                 onchange="updateBuildingNW('${building.name}', 'x', this.value)">
