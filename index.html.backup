    const nyuSlider = document.getElementById('nyuslide');
    if (nyuSlider && BIS && BIS.updateBuildingPosition) {
      const position = parseInt(nyuSlider.value);
      
      // Original positions from building coordinates
      const originalPositions = {
        'NYU Main': { x: 0, y: -10 },
        'NYU North': { x: 75, y: -10 },
        'NYU South': { x: 75, y: -140 },
        'NYU Corner': { x: -1, y: -10 }
      };
      
      // Calculate offset from original position (move South = negative Y)
      const offset = -position;
      
      // Update each cube maintaining its relative position
      BIS.updateBuildingPosition('NYU Main', { y: originalPositions['NYU Main'].y + offset });
      BIS.updateBuildingPosition('NYU North', { y: originalPositions['NYU North'].y + offset });
      BIS.updateBuildingPosition('NYU South', { y: originalPositions['NYU South'].y + offset });
      BIS.updateBuildingPosition('NYU Corner', { y: originalPositions['NYU Corner'].y + offset });
      
      console.log('Initialized NYU positions maintaining relative structure (offset:', offset, '):');
      console.log('  NYU Main:', originalPositions['NYU Main'].y + offset);
      console.log('  NYU North:', originalPositions['NYU North'].y + offset);
      console.log('  NYU South:', originalPositions['NYU South'].y + offset);
      console.log('  NYU Corner:', originalPositions['NYU Corner'].y + offset);
      console.log('(slider value:', position, ')');
      
      drawAll();
    }
  }, 500); // Wait for BIS to initialize
});

function drawPlan(){
  const W=plan.width,PH=plan.height,s=planScale();
  const{x:ox,y:oy}=planOrigin();
  const{cx,cy,ca,fR,FAR,rv1,rv2}=getConeParams(s,ox,oy);
  const tc='#1a1208',mc='#6b5a3e',gc='rgba(139,105,20,0.16)',gl='rgba(100,75,14,0.18)';

  pctx.fillStyle='#faf5ec'; pctx.fillRect(0,0,W,PH);

  // Draw georeferenced historical map
  if(_mapImg.complete && _mapImg.naturalWidth>0 && tempMapVisible){
    pctx.save();
    
    // Debug: Log map info
    console.log('Drawing map:', {
      width: _mapImg.naturalWidth,
      height: _mapImg.naturalHeight,
      scale: tempMapScale,
      rotation: tempMapRotation,
      x: tempMapX,
      y: tempMapY,
      opacity: tempMapOpacity / 100
    });
    
    // Use locked transformation values
    const currentScale = tempMapScale;
    const currentRotation = tempMapRotation * Math.PI / 180;
    const currentX = tempMapX;
    const currentY = tempMapY;
    const currentOpacity = tempMapOpacity / 100;
    
    // Transform: world ft → plan canvas px
    // Plan canvas: px = ox + wx*s, py = oy - wy*s
    // Map image: world (wx,wy) → image px via scale/rotation/anchor
    // We need to position/rotate the image so its anchor aligns with plan canvas anchor
    // Plan canvas position of world origin (0,0):
    const planOx = ox, planOy = oy;
    // The map image pixel (MAP_TX, MAP_TY) corresponds to world (0,0)
    // Map is rotated by currentRotation radians in image space
    // Map scale is currentScale img_px/ft
    // Plan scale is s plan_px/ft
    // Combined scale: s/currentScale plan_px/img_px
    const drawScale = s / currentScale;
    // Move canvas origin to plan position of world (0,0)
    pctx.translate(planOx + currentX*s, planOy + currentY*s);
    // Rotate: map theta is rotation of map grid vs true east
    // In plan canvas, east=+x, north=-y (canvas y flipped)
    // Map rotation in canvas coords = currentRotation (already in correct sign)
    pctx.rotate(currentRotation);
    pctx.scale(drawScale, drawScale);
    // Now draw image so that pixel (MAP_TX, MAP_TY) sits at canvas origin
    pctx.globalAlpha = currentOpacity;
    pctx.drawImage(_mapImg, -MAP_TX, -MAP_TY);
    pctx.globalAlpha = 1.0;
    pctx.restore();
  } else {
    // Debug: Show why map isn't drawing
    console.log('Map not drawing:', {
      complete: _mapImg.complete,
      naturalWidth: _mapImg.naturalWidth,
      naturalHeight: _mapImg.naturalHeight,
      visible: tempMapVisible,
      src: _mapImg.src
    });
    
    // Fallback: Draw test pattern to verify rendering system works
    if(tempMapVisible) {
      // Draw a test pattern to show map area
      pctx.save();
      pctx.translate(W/2, PH/2);
      
      // Draw colored grid pattern
      const gridSize = 50;
      for(let x = -W/2; x < W/2; x += gridSize) {
        for(let y = -PH/2; y < PH/2; y += gridSize) {
          pctx.fillStyle = ((x/gridSize + y/gridSize) % 2 === 0) ? 'rgba(255,200,200,0.5)' : 'rgba(200,200,255,0.5)';
          pctx.fillRect(x, y, gridSize, gridSize);
        }
      }
      
      // Draw text
      pctx.fillStyle = 'black';
      pctx.font = 'bold 16px Arial';
      pctx.textAlign = 'center';
      pctx.fillText('TEST MAP PATTERN', 0, -PH/2 + 30);
      pctx.font = '12px Arial';
      pctx.fillText('Map rendering works - image failed to load', 0, -PH/2 + 50);
      pctx.fillText('Check console for image loading errors', 0, -PH/2 + 70);
      
      pctx.restore();
    }
  }

  // grid removed

  // axes
  pctx.strokeStyle='rgba(100,75,14,0.28)'; pctx.lineWidth=1;
  pctx.beginPath();pctx.moveTo(ox,0);pctx.lineTo(ox,PH);pctx.stroke();
  pctx.beginPath();pctx.moveTo(0,oy);pctx.lineTo(W,oy);pctx.stroke();
  pctx.font='9px "Source Code Pro",monospace'; pctx.fillStyle=mc; pctx.textAlign='left';
  pctx.fillText('(0,0)',ox+3,oy-4);

  // Draw road segments if enabled
  if (showRoadways) {
    drawRoadSegments(pctx, s, ox, oy);
  }

  // cone fill
  pctx.beginPath();pctx.moveTo(cx,cy);pctx.lineTo(rv1.x,rv1.y);pctx.lineTo(rv2.x,rv2.y);pctx.closePath();
  pctx.fillStyle='rgba(0,210,255,0.45)';pctx.fill();

  // blind zones
  function blind(ctx2, px,py,ax,ay,bx,by){
    const sp=extPt(cx,cy,ca,FAR,px,py),sa=extPt(cx,cy,ca,FAR,ax,ay),sb=extPt(cx,cy,ca,FAR,bx,by);
    ctx2.save();
    ctx2.beginPath();ctx2.moveTo(cx,cy);ctx2.lineTo(rv1.x,rv1.y);ctx2.lineTo(rv2.x,rv2.y);ctx2.closePath();ctx2.clip();
    ctx2.fillStyle='rgba(255,0,0,0.7)';
    ctx2.beginPath();ctx2.moveTo(px,py);ctx2.lineTo(ax,ay);ctx2.lineTo(sa.x,sa.y);ctx2.lineTo(sp.x,sp.y);ctx2.closePath();ctx2.fill();
    ctx2.beginPath();ctx2.moveTo(px,py);ctx2.lineTo(bx,by);ctx2.lineTo(sb.x,sb.y);ctx2.lineTo(sp.x,sp.y);ctx2.closePath();ctx2.fill();
    ctx2.restore();
    ctx2.setLineDash([]);
  }
  // Draw shadow zones from BIS
  if (BIS && BIS.getForShadowCasting) {
    const shadowBuildings = BIS.getForShadowCasting();
    shadowBuildings.forEach(building => {
      const { coords } = building;
      const x0 = ox + coords.x0 * s;
      const y0 = oy - coords.y1 * s;  // y1 is the north edge, so subtract from oy
      const width = (coords.x1 - coords.x0) * s;
      const height = (coords.y1 - coords.y0) * s;
      
      blind(pctx, x0, y0, x0 + width, y0, x0, y0 + height);
    });
  }

  // cone edges
  pctx.setLineDash([]);pctx.lineWidth=1.5;pctx.strokeStyle='rgba(255,0,0,1)'; // Bright red for middle line
  pctx.beginPath();pctx.moveTo(cx,cy);pctx.lineTo(cx+Math.cos(ca)*120,cy+Math.sin(ca)*120);pctx.stroke();

  // Draw all buildings from BIS (Building Info System)
  if (BIS && BIS.getForPlanView) {
    const bisBuildings = BIS.getForPlanView();
    console.log('Plan view BIS buildings:', bisBuildings);
    console.log('Number of buildings for plan view:', bisBuildings.length);
    bisBuildings.forEach(building => {
      const { coords, col, name, sections } = building;
      const x0 = ox + coords.x0 * s;
      const y0 = oy - coords.y1 * s;  // y1 is the north edge, so subtract from oy
      const width = (coords.x1 - coords.x0) * s;
      const height = (coords.y1 - coords.y0) * s;
      
      console.log(`Plan view drawing ${name}: coords(${coords.x0},${coords.y0}) to (${coords.x1},${coords.y1}) -> pixels(${x0},${y0}) size(${width},${height})`);
      
      // Regular building rendering for all buildings
        pctx.fillStyle = col;
        pctx.strokeStyle = col.replace(/[\d.]+\)$/, '1)');
        pctx.lineWidth = 1.5;
        pctx.beginPath();
        pctx.rect(x0, y0, width, height);
        pctx.fill();
        pctx.stroke();
        
        // Building label
        pctx.fillStyle = '#000000';
        pctx.font = '700 8px "Source Code Pro", monospace';
        pctx.textAlign = 'center';
        pctx.fillText(name, x0 + width/2, y0 + height/2 + 3);
        
        // Add NYU corner stripes for face boundaries
        if (name === 'NYU') {
          pctx.strokeStyle = 'rgba(50,50,50,0.8)';
          pctx.lineWidth = 2;
          
          // West edge stripe
          pctx.beginPath();
          pctx.moveTo(x0, y0);
          pctx.lineTo(x0, y0 + height);
          pctx.stroke();
          
          // East edge stripe  
          pctx.beginPath();
          pctx.moveTo(x0 + width, y0);
          pctx.lineTo(x0 + width, y0 + height);
          pctx.stroke();
          
          // North edge stripe
          pctx.beginPath();
          pctx.moveTo(x0, y0);
          pctx.lineTo(x0 + width, y0);
          pctx.stroke();
          
          // South edge stripe
          pctx.beginPath();
          pctx.moveTo(x0, y0 + height);
          pctx.lineTo(x0 + width, y0 + height);
          pctx.stroke();
        }
    });
  }

  
  // corner dots - origin only
  pctx.fillStyle='#3a3020';
  pctx.beginPath();pctx.arc(ox,oy,3,0,Math.PI*2);pctx.fill();

  // camera crosshair
  pctx.strokeStyle='rgba(192,57,43,0.22)';pctx.lineWidth=0.8;pctx.setLineDash([3,3]);
  pctx.beginPath();pctx.moveTo(cx,0);pctx.lineTo(cx,PH);pctx.stroke();
  pctx.beginPath();pctx.moveTo(0,cy);pctx.lineTo(W,cy);pctx.stroke();pctx.setLineDash([]);

  // camera dot
  pctx.fillStyle='#c0392b';pctx.beginPath();pctx.arc(cx,cy,4,0,Math.PI*2);pctx.fill();
  pctx.fillStyle='black';pctx.font='bold 6px monospace';pctx.textAlign='center';pctx.fillText('C',cx,cy+2);

  // cursor indicator
  if (cursorFtX !== 0 || cursorFtY !== 0) {
    const cursorPx = ox + cursorFtX * s;
    const cursorPy = oy - cursorFtY * s; // Y is flipped
    
    // Only draw if cursor is within canvas bounds
    if (cursorPx >= 0 && cursorPx <= W && cursorPy >= 0 && cursorPy <= PH) {
      // Draw cursor crosshair
      pctx.strokeStyle='rgba(52,152,219,0.6)';pctx.lineWidth=1;pctx.setLineDash([2,2]);
      pctx.beginPath();pctx.moveTo(cursorPx, cursorPy - 8);pctx.lineTo(cursorPx, cursorPy + 8);pctx.stroke();
      pctx.beginPath();pctx.moveTo(cursorPx - 8, cursorPy);pctx.lineTo(cursorPx + 8, cursorPy);pctx.stroke();pctx.setLineDash([]);
      
      // Draw cursor dot
      pctx.fillStyle='#3498db';pctx.beginPath();pctx.arc(cursorPx, cursorPy, 3, 0, Math.PI * 2);pctx.fill();
    }
  }

  // Permanent ruler (1300 feet total, from -300 to +1000)
  const rulerY = oy - 30 * s; // Position 30 feet north of origin
  const rulerStartX = ox - 300 * s; // Start 300 feet left of origin
  const rulerEndX = ox + 1000 * s;  // End 1000 feet right of origin (total 1300 feet)
  
  // Ruler line
  pctx.strokeStyle = '#333333';
  pctx.lineWidth = 2;
  pctx.beginPath();
  pctx.moveTo(rulerStartX, rulerY);
  pctx.lineTo(rulerEndX, rulerY);
  pctx.stroke();
  
  // Ruler tick marks every 100 feet (asymmetric range -300 to +1000)
  pctx.strokeStyle = '#333333';
  pctx.lineWidth = 1;
  
  // Create tick marks for -300 to +1000
  const tickPositions = [-300, -200, -100, 0, 100, 200, 300, 400, 500, 600, 700, 800, 900, 1000];
  
  tickPositions.forEach(position => {
    const x = ox + (position * s);
    const tickHeight = (position === 0) ? 10 : 8; // Taller tick at origin
    
    pctx.beginPath();
    pctx.moveTo(x, rulerY - tickHeight/2);
    pctx.lineTo(x, rulerY + tickHeight/2);
    pctx.stroke();
  });
  
  // Ruler labels
  pctx.fillStyle = '#333333';
  pctx.font = '10px "Source Code Pro", monospace';
  pctx.textAlign = 'center';
  pctx.textBaseline = 'top';
  
  // Label from -300 to +1000 feet, with 0 at origin
  tickPositions.forEach(position => {
    const x = ox + (position * s);
    const label = (position === 0) ? '0' : (position > 0 ? `+${position}` : `${position}`);
    pctx.fillText(label, x, rulerY + 6);
  });

  
  // N arrow removed - not true north

  // ── Draw tape measure ───────────────────────────────────────────────────────
  if (tapeMeasureMode && tapeMeasureStart && tapeMeasureEnd) {
    const startPx = worldToPx(tapeMeasureStart.x, tapeMeasureStart.y);
    const endPx = worldToPx(tapeMeasureEnd.x, tapeMeasureEnd.y);
    
    // Draw tape measure line
    pctx.strokeStyle = '#e74c3c';
    pctx.lineWidth = 3;
    pctx.setLineDash([8, 4]);
    pctx.beginPath();
    pctx.moveTo(startPx.x, startPx.y);
    pctx.lineTo(endPx.x, endPx.y);
    pctx.stroke();
    pctx.setLineDash([]);
    
    // Draw start point
    pctx.fillStyle = '#e74c3c';
    pctx.beginPath();
    pctx.arc(startPx.x, startPx.y, 5, 0, Math.PI * 2);
    pctx.fill();
    
    // Draw end point
    pctx.fillStyle = '#e74c3c';
    pctx.beginPath();
    pctx.arc(endPx.x, endPx.y, 5, 0, Math.PI * 2);
    pctx.fill();
    
    // Draw distance label at midpoint
    const midPx = {
      x: (startPx.x + endPx.x) / 2,
      y: (startPx.y + endPx.y) / 2
    };
    const distance = calculateDistance(tapeMeasureStart, tapeMeasureEnd);
    
    // Background for text (transparent)
    pctx.fillStyle = 'rgba(255, 255, 255, 0.1)';
    pctx.fillRect(midPx.x - 30, midPx.y - 12, 60, 24);
    
    // Text
    pctx.fillStyle = '#000000';
    pctx.font = 'bold 12px "Source Code Pro", monospace';
    pctx.textAlign = 'center';
    pctx.textBaseline = 'middle';
    pctx.fillText(`${distance.toFixed(1)} ft`, midPx.x, midPx.y);
  }

  
  pctx.restore();
}

// ── Ray-Casting System ────────────────────────────────────────
let plateStrip, psctx;

function drawAll(){
  updateCoords();
  drawPlan();
  updateRayCasting();
}

// ── Text-to-Speech for Accessibility ───────────────────────────────────────
function speakInstruction(topic) {
  // Cancel any ongoing speech
  window.speechSynthesis.cancel();
  
  const instructions = {
    'camera-position': 'Camera Position: Control camera with X/Y sliders for east-west and north-south movement, plus height adjustment. Use exact inputs for precision. Camera moves freely - negative X is west, positive Y is north. Height sets eye level from 3-35 feet.',
    
    'camera-rotation': 'Camera Rotation: 0° aims east toward NYU. Positive rotates north, negative south. Controls camera direction.',
    
    'field-of-view': function() {
      const focalLength = parseFloat(document.getElementById('focal').value);
      const fovDeg = getFovDeg();
      const plateWidthInches = getPlateWidth();
      const plateHeightInches = getPlateHeight();
      const vFovDeg = fovDeg * (plateHeightInches/plateWidthInches);
      const plateSize = currentPlateSize;
      return `Field of View: FOV calculated from focal length. At ${focalLength}" focal length, horizontal FOV is ${fovDeg.toFixed(1)}° and vertical is ${vFovDeg.toFixed(1)}° for ${plateSize} inch plate. Adjust focal length to change perspective.`;
    },
    
    'image-overlay': 'Plate H Overlay: Load the 1839 daguerreotype Plate H from McManus Collection to overlay on the simulated view. Adjust opacity slider (0-100%) to blend the historical photograph with the simulation for comparison.',
    
    'building-movement': 'Building Movement: Shift buildings north or south. Changes appear instantly in plan and ray-casting views. Test historical placement hypotheses.',
    
    'historical-map': 'Historical Map: The 1852 Harrison map underlies the plan at georeferenced scale. Origin (0,0) is the NYU NW corner. The Church of the Messiah is 777 ft to the east - matching current NYC online system measurements.',
    
    'map-controls': 'Map Controls: Toggle map positioning controls to scale, rotate, and offset the 1852 Harrison map. Save and load map positions for consistent reference. Adjust opacity and visibility for overlay comparison.',
    
    'tape-measure': 'Tape Measure: Click and drag to measure distances between any two points on the plan. Distance displays in feet with transparent blue label. Use for precise spatial analysis and measurements.',
    
    'building-info': 'Building Info: Toggle building information display to view detailed data about NYU, Row Houses, and Church buildings. Shows coordinates, dimensions, and properties for historical analysis.'
  };
  
  const text = typeof instructions[topic] === 'function' ? instructions[topic]() : instructions[topic];
  if (text) {
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.rate = 0.9; // Slightly slower for clarity
    utterance.pitch = 1.0;
    utterance.volume = 1.0;
    
    // Find a voice that speaks clearly
    const voices = window.speechSynthesis.getVoices();
    const preferredVoice = voices.find(voice => 
      voice.name.includes('Google') || 
      voice.name.includes('Microsoft') ||
      voice.lang.startsWith('en')
    );
    
    if (preferredVoice) {
      utterance.voice = preferredVoice;
    }
    
    window.speechSynthesis.speak(utterance);
  }
}

// Load voices when available
window.speechSynthesis.getVoices();
if (speechSynthesis.onvoiceschanged !== undefined) {
  speechSynthesis.onvoiceschanged = function() {
    speechSynthesis.getVoices();
  };
}

window.addEventListener('resize',setup);

// Initialize setup after DOM is loaded
document.addEventListener('DOMContentLoaded', function() {
  setup();
  // Initialize camera inputs with current position
  const camXInput = document.getElementById('camX-input');
  const camYInput = document.getElementById('camY-input');
  if (camXInput) camXInput.value = Math.round(camFtX);
  if (camYInput) camYInput.value = Math.round(camFtY);
  
  // Initialize plate size selector and canvas
  const plateSizeSelector = document.getElementById('plate-size-selector');
  if (plateSizeSelector) {
    // Get the currently selected plate size
    currentPlateSize = plateSizeSelector.value;
    console.log('DEBUG: Initial plate size from selector:', currentPlateSize);
    
    // Update canvas dimensions based on initial plate size
    updatePlateCanvasSize();
    
    // Update instruction display
    document.getElementById('instr-plate-size').textContent = getDisplayName(currentPlateSize);
  }
  
  // Force an initial redraw after a short delay to ensure all elements are ready
  setTimeout(() => drawAll(), 100);
});

// Building AABBs in world coords (X=east, Y=north, origin=ZZZ NW corner)
// Each: {x0,x1,y0,y1, wCol (west face), sCol (other faces), name}
// Unified coordinate system - single source of truth for all building positions
function getUnifiedBuildingCoordinates(){
  // ZZZ building (hidden)
  const zzz = {
    x0: -999999, x1: -999998, y0: -999999, y1: -999998,
    h: 0.001, col: 'rgba(216,213,208,0.01)', name: 'ZZZ'
  };
  
  // RH1 building - hidden at far coordinates to preserve dependencies
  const rh1 = {
    x0: -999999, x1: -999998, y0: -999999, y1: -999998,
    h: 0.001, col: 'rgba(196,98,64,0.01)', name: 'RH1'  // Almost transparent
  };
  
  // RH2 building - hidden at far coordinates to preserve dependencies  
  const rh2 = {
    x0: -999999, x1: -999998, y0: -999999, y1: -999998,
    h: 0.001, col: 'rgba(210,140,60,0.01)', name: 'RH2'  // Almost transparent
  };
  
  // Church building - hidden at far coordinates to preserve dependencies
  const church = {
    x0: -999999, x1: -999998,
    y0: -999999, y1: -999998,
    sections: [
      {x0: -999999, x1: -999998, y0: -999999, y1: -999998, h: 0.001, col: 'rgba(26,79,204,0.01)', name: 'ChN'},
      {x0: -999999, x1: -999998, y0: -999999, y1: -999998, h: 0.001, col: 'rgba(105,190,40,0.01)', name: 'ChM'},
      {x0: -999999, x1: -999998, y0: -999999, y1: -999998, h: 0.001, col: 'rgba(160,190,40,0.01)', name: 'ChMid'},
      {x0: -999999, x1: -999998, y0: -999999, y1: -999998, h: 0.001, col: 'rgba(255,238,0,0.01)', name: 'ChS'}
    ]
  };
  
  return { zzz, rh1, rh2, church };
}

// ── Intermediate Building Coordinate System ────────────────────────────
class BuildingCoordinates {
  constructor() {
    this.buildings = new Map();
    this.initializeDefaults();
  }
  
  initializeDefaults() {
    // NYU Three-Cube Structure: Main 75x180 + two 25x50 side cubes forming C-shape with open end pointing east
    this.buildings.set('NYU Main', {
      nw: { x: 0, y: -10 },     // NW corner coordinates (user specified)
      wDist: 75,                // West-to-East distance (width) - main cube
      nDist: 180,               // North-to-South distance (length) - main cube
      ht: 85,                   // Height
      color: 'rgba(128,128,128,0.6)',  // NYU gray building color
      type: 'building',
      source: 'user',           // Required for ray-casting visibility
      faceColors: {
        w: null,
        e: null,
        n: null,
        s: 'rgba(98,98,98,0.6)',  // South face - darker gray shade
        t: null
      }
    });
    
    this.buildings.set('NYU North', {
      nw: { x: 75, y: -10 },    // NW corner coordinates (user specified)
      wDist: 25,                // West-to-East distance (width) - side cube
      nDist: 50,                // North-to-South distance (length) - side cube
      ht: 85,                   // Height
      color: 'rgba(100,100,100,0.6)',  // Darker gray for side cube
      type: 'building',
      source: 'user',           // Required for ray-casting visibility
      faceColors: {
        w: null,
        e: null,
        n: 'rgba(70,70,70,0.6)',  // North face - darker shade
        s: null,
        t: null
      }
    });
    
    this.buildings.set('NYU South', {
      nw: { x: 75, y: -140 },   // NW corner coordinates (user specified)
      wDist: 25,                // West-to-East distance (width) - side cube
      nDist: 50,                // North-to-South distance (length) - side cube
      ht: 85,                   // Height
      color: 'rgba(100,100,100,0.6)',  // Darker gray for side cube
      type: 'building',
      source: 'user',           // Required for ray-casting visibility
      faceColors: {
        w: null,
        e: null,
        n: null,
        s: 'rgba(70,70,70,0.6)',  // South face - darker shade
        t: null
      }
    });
    
    // NYU Corner building - 0.25x0.25 black block at upper left corner
    this.buildings.set('NYU Corner', {
      nw: { x: -1, y: -10 },    // Position at NYU upper left corner (user specified)
      wDist: 0.25,              // 0.25ft width
      nDist: 0.25,              // 0.25ft length
      ht: 85,                   // Same height as NYU
      color: 'black',           // Black block
      type: 'building',
      source: 'user',           // Required for ray-casting visibility
      faceColors: {
        w: null,
        e: null,
        n: null,
        s: null,
        t: null
      }
    });
    
    this.buildings.set('RH1', {
      nw: { x: 0, y: 10 },     // NW corner coordinates
      wDist: 112,               // West-to-East distance
      nDist: 50,                // North-to-South distance
      ht: 45,                   // Height
      color: 'rgba(128,0,0,0.4)',  // Maroon rowhouse color
      type: 'building',
      faceColors: {
        w: 'rgba(98,0,0,0.4)',  // West face - darker maroon shade
        e: null,
        n: null,
        s: null,
        t: null
      }
    });
    
    this.buildings.set('RH2', {
      nw: { x: 0, y: 10 },     // NW corner coordinates
      wDist: 180,               // West-to-East distance
      nDist: 50,                // North-to-South distance
      ht: 45,                   // Height
      color: 'rgba(139,90,43,0.5)',  // Brown earth tone rowhouse color
      type: 'building',
      faceColors: {
        w: null,
        e: 'rgba(109,60,13,0.5)',  // East face - darker brown shade
        n: null,
        s: null,
        t: null
      }
    });
    
    // Three separate church buildings with different heights and colors
    this.buildings.set('Church North', {
      nw: { x: churchDistance, y: 0 },   // NW corner coordinates (dynamic from slider)
      wDist: 92,                // West-to-East distance (reduced by 8 ft for wider Mercer Street)
      nDist: 25,                // North-to-South distance (1/3 of original)
      ht: 50,                   // Height
      color: 'rgba(0,128,0,0.5)',  // Green - 50% opaque
      type: 'building',
      faceColors: {
        w: null,
        e: null,
        n: 'rgba(0,102,0,0.5)',  // North face - darker shade, 50% opaque
        s: null,
        t: null
      }
    });
    
    this.buildings.set('Church Middle', {
      nw: { x: churchDistance, y: -25 },    // NW corner coordinates (dynamic from slider)
      wDist: 92,                // West-to-East distance (reduced by 8 ft for wider Mercer Street)
      nDist: 25,                // North-to-South distance (1/3 of original)
      ht: 90,                   // Height
      color: 'rgba(255,255,0,0.5)',  // Yellow - 50% opaque
      type: 'building',
      faceColors: {
        w: null,
        e: null,
        n: null,
        s: 'rgba(204,204,0,0.5)',  // South face - darker shade, 50% opaque
        t: null
      }
    });
    
    this.buildings.set('Church South', {
      nw: { x: churchDistance, y: -50 },  // NW corner coordinates (dynamic from slider)
      wDist: 92,                // West-to-East distance (reduced by 8 ft for wider Mercer Street)
      nDist: 25,                // North-to-South distance (1/3 of original)
      ht: 50,                   // Height
      color: 'rgba(0,0,255,0.5)',  // Blue - 50% opaque
      type: 'building',
      faceColors: {
        w: 'rgba(0,0,204,0.5)',  // West face - darker shade, 50% opaque
        e: null,
        n: null,
        s: null,
        t: null
      }
    });
    
    // Streets using NW, WDist, NDist, Ht system
    this.buildings.set('Washington Square East', {
      nw: { x: -50, y: 30 },    // NW corner coordinates
      wDist: 50,                // West-to-East distance (width)
      nDist: 330,               // North-to-South distance (length)
      ht: 2,                    // Height (road height)
      color: 'rgba(205,133,63,0.8)',  // Clay-colored roadways
      type: 'street'
    });
    
    this.buildings.set('University Place', {
      nw: { x: -50, y: 300 },   // NW corner coordinates
      wDist: 75,                // West-to-East distance (width)
      nDist: 300,               // North-to-South distance (length)
      ht: 2,                    // Height (road height)
      color: 'rgba(205,133,63,0.8)',  // Clay-colored roadways
      type: 'street'
    });
    
    this.buildings.set('Waverly Place', {
      nw: { x: 0, y: 60 },      // NW corner coordinates
      wDist: 702,               // West-to-East distance (width)
      nDist: 60,                // North-to-South distance (length)
      ht: 2,                    // Height (road height)
      color: 'rgba(205,133,63,0.8)',  // Clay-colored roadways
      type: 'street'
    });
    
    this.buildings.set('Broadway', {
      nw: { x: 702, y: 300 },   // NW corner coordinates
      wDist: 75,                // West-to-East distance (width) - updated to 75ft
      nDist: 600,               // North-to-South distance (length)
      ht: 2,                    // Height (road height)
      color: 'rgba(205,133,63,0.8)',  // Clay-colored roadways
      type: 'street'
    });
    
    this.buildings.set('Washington Square North', {
      nw: { x: -300, y: 60 },   // NW corner coordinates
      wDist: 300,               // West-to-East distance (width)
      nDist: 60,                // North-to-South distance (length)
      ht: 2,                    // Height (road height)
      color: 'rgba(205,133,63,0.8)',  // Clay-colored roadways
      type: 'street'
    });
    
    this.buildings.set('Greene Street', {
      nw: { x: 208, y: 300 },   // NW corner coordinates
      wDist: 40,                // West-to-East distance (width)
      nDist: 600,               // North-to-South distance (length)
      ht: 2,                    // Height (road height)
      color: 'rgba(205,133,63,0.8)',  // Clay-colored roadways
      type: 'street'
    });
    
    this.buildings.set('Mercer Street', {
      nw: { x: 458, y: 300 },   // NW corner coordinates
      wDist: 48,                // West-to-East distance (width)
      nDist: 600,               // North-to-South distance (length)
      ht: 2,                    // Height (road height)
      color: 'rgba(205,133,63,0.8)',  // Clay-colored roadways
      type: 'street'
    });
    
    this.buildings.set('Washington Place', {
      nw: { x: 0, y: -197 },    // NW corner coordinates
      wDist: 702,               // West-to-East distance (width)
      nDist: 70,                // North-to-South distance (length)
      ht: 2,                    // Height (road height)
      color: 'rgba(205,133,63,0.8)',  // Clay-colored roadways
      type: 'street'
    });
  }
  
  // Convert to BIS format
  toBISFormat() {
    const bisData = new Map();
    
    this.buildings.forEach((building, name) => {
      const nw = building.nw;
      
      // Debug: Log building dimensions during conversion
      console.log(`Converting ${name} to BIS format: wDist=${building.wDist}, nDist=${building.nDist}`);
      console.log(`Full building object for ${name}:`, building);
      
      // Special debugging for NYU Corner
      if (name === 'NYU Corner') {
        console.log('NYU Corner detailed debug:');
        console.log('  building.wDist:', building.wDist, 'type:', typeof building.wDist);
        console.log('  building.nDist:', building.nDist, 'type:', typeof building.nDist);
        console.log('  building.nw:', building.nw);
        console.log('  Is wDist undefined?', building.wDist === undefined);
        console.log('  Is nDist undefined?', building.nDist === undefined);
      }
      
      // Hardcode NYU Corner to 1 foot square
      let width = building.wDist;
      let length = building.nDist;
      
      if (name === 'NYU Corner') {
        width = 0.25;
        length = 0.25;
        console.log('Hardcoding NYU Corner to 0.25ft x 0.25ft');
      }
      
      const bisBuilding = {
        name: name,
        nwCoordinate: { x: nw.x, y: nw.y },
        dimensions: { width: width, length: length },
        height: building.ht,
        color: building.color,
        position: {
          x0: nw.x,                    // NW corner
          x1: nw.x + width,            // NE corner (use hardcoded width)
          y0: nw.y - length,           // SW corner (use hardcoded length)
          y1: nw.y                     // NW corner
        },
        source: 'user',
        type: building.type || 'building'
      };
      
      // Add sections for Church
      if (building.sections) {
        bisBuilding.sections = building.sections;
      }
      
      bisData.set(name, bisBuilding);
    });
    
    return bisData;
  }
  
  // Update building coordinates
  updateBuilding(buildingName, updates) {
    const building = this.buildings.get(buildingName);
    if (building) {
      Object.assign(building, updates);
      console.log(`Updated ${buildingName}:`, building);
    }
  }
}

// ── Building Info System (BIS) - Primary Data Source ───────────────────────
class BuildingInfoSystem {
  constructor() {
    this.buildingData = new Map();
    this.coordinateSystem = new BuildingCoordinates();
    this.initializeBuildingData();
  }
  
  initializeBuildingData() {
    // Initialize from intermediate coordinate system
    this.buildingData = this.coordinateSystem.toBISFormat();
  }
  
  getAllBuildings() {
    return Array.from(this.buildingData.values());
  }
  
  getBuildingInfo(buildingName) {
    return this.buildingData.get(buildingName);
  }
  
  getBuildingsByType(type) {
    const buildings = Array.from(this.buildingData.values());
    switch(type) {
      case 'visible':
        return buildings.filter(b => b.source === 'user' && b.type !== 'street'); // Exclude streets from ray-casting
      case 'hidden':
        return buildings.filter(b => b.source === 'unified');
      case 'multi-section':
        return buildings.filter(b => b.sections);
      default:
        return buildings;
    }
  }
  
  // System-specific methods
  getForPlanView() {
    // For plan view, include all user buildings except streets (streets handled by drawRoadSegments)
    const buildings = Array.from(this.buildingData.values());
    const planBuildings = buildings.filter(b => b.source === 'user' && b.type !== 'street');
    return planBuildings.map(building => ({
      name: building.name,
      coords: building.position,
      col: building.color
    }));
  }
  
  getForShadowCasting() {
    const visibleBuildings = this.getBuildingsByType('visible');
    return visibleBuildings.map(building => ({
      coords: building.position
    }));
  }
  
  getForRayCasting() {
    // Only return visible buildings for ray-casting
    const visibleBuildings = this.getBuildingsByType('visible');
    
    // Debug: Log all buildings and their source properties
    console.log('All BIS buildings and their source:');
    this.getAllBuildings().forEach(b => {
      console.log(`  ${b.name}: source="${b.source}", type="${b.type}"`);
    });
    
    console.log('Visible buildings for ray-casting:', visibleBuildings.map(b => b.name));
    
    return visibleBuildings.map(building => ({
      name: building.name,
      x0: building.position.x0,
      x1: building.position.x1,
      y0: building.position.y0,
      y1: building.position.y1,
      h: building.height,
      col: building.color
    }));
  }

  // Update building position
  updateBuildingPosition(buildingName, position) {
    const coordBuilding = this.coordinateSystem.buildings.get(buildingName);
    if (coordBuilding) {
      // Update NW coordinate in intermediate system
      if (position.y !== undefined) {
        coordBuilding.nw.y = position.y;
      }
      if (position.x !== undefined) {
        coordBuilding.nw.x = position.x;
      }
      
      // Update BIS data from intermediate system
      const bisBuilding = this.buildingData.get(buildingName);
      if (bisBuilding) {
        bisBuilding.nwCoordinate = { ...coordBuilding.nw };
        
        // Hardcode NYU Corner dimensions in position updates
        let wDist = coordBuilding.wDist;
        let nDist = coordBuilding.nDist;
        
        if (buildingName === 'NYU Corner') {
          wDist = 0.25;
          nDist = 0.25;
          console.log('Hardcoding NYU Corner position to 0.25ft x 0.25ft');
        }
        
        bisBuilding.position = {
          x0: coordBuilding.nw.x,
          x1: coordBuilding.nw.x + wDist,
          y0: coordBuilding.nw.y - nDist,
          y1: coordBuilding.nw.y
        };
        // Ensure source property is always preserved during updates
        bisBuilding.source = 'user';
        
        // Special handling for NYU Corner to ensure it's always visible
        if (buildingName === 'NYU Corner') {
          bisBuilding.source = 'user';
          bisBuilding.dimensions = { width: 0.25, length: 0.25 };
          console.log('Force-preserved source and dimensions for NYU Corner');
        }
      }
      console.log(`Updated ${buildingName} position:`, coordBuilding.nw);
    }
  }

  // Update building height
  updateBuildingHeight(buildingName, height) {
    const coordBuilding = this.coordinateSystem.buildings.get(buildingName);
    if (coordBuilding) {
      coordBuilding.ht = height;
      
      // Update BIS data from intermediate system
      const bisBuilding = this.buildingData.get(buildingName);
      if (bisBuilding) {
        bisBuilding.height = height;
        // Ensure source property is always preserved during height updates
        bisBuilding.source = 'user';
        
        // Special handling for NYU Corner to ensure it's always visible
        if (buildingName === 'NYU Corner') {
          bisBuilding.source = 'user';
          console.log('Force-preserved source for NYU Corner in height update');
        }
      }
      console.log(`Updated ${buildingName} height:`, height);
    }
  }

  // Update building WDIST (West-to-East distance)
  updateBuildingWDist(buildingName, wDist) {
    const coordBuilding = this.coordinateSystem.buildings.get(buildingName);
    if (coordBuilding) {
      coordBuilding.wDist = parseInt(wDist);
      
      // Update BIS data from intermediate system
      const bisBuilding = this.buildingData.get(buildingName);
      if (bisBuilding) {
        bisBuilding.dimensions.width = coordBuilding.wDist;
        bisBuilding.position.x1 = coordBuilding.nw.x + coordBuilding.wDist;
      }
      console.log(`Updated ${buildingName} WDIST:`, wDist);
    }
  }

  // Update building NDIST (North-to-South distance)
  updateBuildingNDist(buildingName, nDist) {
    const coordBuilding = this.coordinateSystem.buildings.get(buildingName);
    if (coordBuilding) {
      coordBuilding.nDist = parseInt(nDist);
      
      // Update BIS data from intermediate system
      const bisBuilding = this.buildingData.get(buildingName);
      if (bisBuilding) {
        bisBuilding.dimensions.length = coordBuilding.nDist;
        bisBuilding.position.y0 = coordBuilding.nw.y - coordBuilding.nDist;
      }
      console.log(`Updated ${buildingName} NDIST:`, nDist);
    }
  }

  // Update Church section height
  updateChurchSectionHeight(sectionName, height) {
    const church = this.buildingData.get('Church');
    if (church && church.sections) {
      const section = church.sections.find(s => s.name === sectionName);
      if (section) {
        section.height = height;
        // Update overall church height to max of sections
        church.height = Math.max(...church.sections.map(s => s.height));
        console.log(`Updated Church ${sectionName} height:`, height, 'Overall church height:', church.height);
      }
    }
  }

  // Get specific building
  getBuilding(buildingName) {
    return this.buildingData.get(buildingName);
  }
}

// Global functions for BIS input updates
function updateBuildingNW(buildingName, axis, value) {
  if (BIS && BIS.updateBuildingPosition) {
    const position = {};
    position[axis] = parseInt(value);
    BIS.updateBuildingPosition(buildingName, position);
    drawAll(); // Redraw all canvases
  }
}

function updateBuildingWDist(buildingName, wDist) {
  if (BIS && BIS.updateBuildingWDist) {
    BIS.updateBuildingWDist(buildingName, wDist);
    drawAll(); // Redraw all canvases
  }
}

function updateBuildingNDist(buildingName, nDist) {
  if (BIS && BIS.updateBuildingNDist) {
    BIS.updateBuildingNDist(buildingName, nDist);
    drawAll(); // Redraw all canvases
  }
}

function updateBuildingHeight(buildingName, height) {
  if (BIS && BIS.updateBuildingHeight) {
    BIS.updateBuildingHeight(buildingName, parseInt(height));
    drawAll(); // Redraw all canvases
  }
}

function refreshScene() {
  drawAll(); // Redraw all canvases
  console.log('Scene refreshed');
}

// Map controls functions
function toggleMapControls() {
  const mapControls = document.getElementById('map-controls');
  const toggle = document.getElementById('map-controls-toggle');
  
  if (mapControls.style.display === 'none') {
    mapControls.style.display = 'block';
    toggle.textContent = 'Exit Map';
    toggle.style.background = 'var(--rust)';
    toggle.style.color = 'var(--paper)';
  } else {
    mapControls.style.display = 'none';
    toggle.textContent = 'MAP';
    toggle.style.background = 'var(--paper)';
    toggle.style.color = 'var(--ink)';
  }
}

function updateMapPosition() {
  // Update temporary map variables from sliders
  tempMapScale = parseFloat(document.getElementById('mapScale').value);
  tempMapRotation = parseFloat(document.getElementById('mapRotation').value);
  tempMapX = parseFloat(document.getElementById('mapOffsetX').value);
  tempMapY = parseFloat(document.getElementById('mapOffsetY').value);
  tempMapVisible = document.getElementById('tempMapVisible').checked;
  showRoadways = document.getElementById('showRoadways').checked;
  tempMapOpacity = parseFloat(document.getElementById('mapOpacity').value);
  
  // Update display values and input fields
  document.getElementById('mapScale-out').textContent = tempMapScale.toFixed(2);
  document.getElementById('mapScale-input').value = tempMapScale.toFixed(2);
  document.getElementById('mapRotation-out').textContent = tempMapRotation.toFixed(1) + '°';
  document.getElementById('mapRotation-input').value = tempMapRotation.toFixed(1);
  document.getElementById('mapOffsetX-out').textContent = Math.round(tempMapX);
  document.getElementById('mapOffsetX-input').value = Math.round(tempMapX);
  document.getElementById('mapOffsetY-out').textContent = Math.round(tempMapY);
  document.getElementById('mapOffsetY-input').value = Math.round(tempMapY);
  document.getElementById('mapOpacity-out').textContent = Math.round(tempMapOpacity) + '%';
  
  // Redraw the scene
  drawAll();
}

function updateMapFromInput() {
  // Update temporary map variables from input fields
  tempMapScale = parseFloat(document.getElementById('mapScale-input').value);
  tempMapRotation = parseFloat(document.getElementById('mapRotation-input').value);
  tempMapX = parseFloat(document.getElementById('mapOffsetX-input').value);
  tempMapY = parseFloat(document.getElementById('mapOffsetY-input').value);
  tempMapVisible = document.getElementById('tempMapVisible').checked;
  tempMapOpacity = parseFloat(document.getElementById('mapOpacity').value);
  
  // Update sliders and display values
  document.getElementById('mapScale').value = tempMapScale;
  document.getElementById('mapScale-out').textContent = tempMapScale.toFixed(2);
  document.getElementById('mapRotation').value = tempMapRotation;
  document.getElementById('mapRotation-out').textContent = tempMapRotation.toFixed(1) + '°';
  document.getElementById('mapOffsetX').value = tempMapX;
  document.getElementById('mapOffsetX-out').textContent = Math.round(tempMapX);
  document.getElementById('mapOffsetY').value = tempMapY;
  document.getElementById('mapOffsetY-out').textContent = Math.round(tempMapY);
  document.getElementById('mapOpacity').value = tempMapOpacity;
  document.getElementById('mapOpacity-out').textContent = Math.round(tempMapOpacity) + '%';
  
  // Redraw the scene
  drawAll();
}

function saveMapSettings() {
  const mapSettings = {
    scale: tempMapScale,
    rotation: tempMapRotation,
    x: tempMapX,
    y: tempMapY,
    visible: tempMapVisible,
    timestamp: new Date().toISOString()
  };
  
  // Save to map-specific localStorage
  const storageKey = 'plateH_map' + currentMapIndex + '_settings';
  localStorage.setItem(storageKey, JSON.stringify(mapSettings));
  
  console.log('DEBUG: Saving settings for map index:', currentMapIndex);
  console.log('DEBUG: Storage key:', storageKey);
  console.log('Map settings saved for', MAP_CONFIGS[currentMapIndex].name, ':', mapSettings);
  
  // Visual feedback
  const saveBtn = document.getElementById('saveMapPosition');
  const originalText = saveBtn.textContent;
  saveBtn.textContent = 'Saved!';
  saveBtn.style.background = 'var(--sepia)';
  saveBtn.style.color = 'var(--paper)';
  
  setTimeout(() => {
    saveBtn.textContent = originalText;
    saveBtn.style.background = 'var(--paper)';
    saveBtn.style.color = 'var(--ink)';
  }, 1500);
}

function resetMapToOrigin() {
  // Reset map to origin position
  tempMapScale = 1.0;
  tempMapRotation = 0.0;
  tempMapX = 0;
  tempMapY = 0;
  tempMapVisible = true;
  
  // Update all controls
  document.getElementById('mapScale').value = tempMapScale;
  document.getElementById('mapScale-input').value = tempMapScale;
  document.getElementById('mapScale-out').textContent = tempMapScale.toFixed(2);
  
  document.getElementById('mapRotation').value = tempMapRotation;
  document.getElementById('mapRotation-input').value = tempMapRotation;
  document.getElementById('mapRotation-out').textContent = tempMapRotation.toFixed(1) + '°';
  
  document.getElementById('mapOffsetX').value = tempMapX;
  document.getElementById('mapOffsetX-input').value = tempMapX;
  document.getElementById('mapOffsetX-out').textContent = Math.round(tempMapX);
  
  document.getElementById('mapOffsetY').value = tempMapY;
  document.getElementById('mapOffsetY-input').value = tempMapY;
  document.getElementById('mapOffsetY-out').textContent = Math.round(tempMapY);
  
  document.getElementById('tempMapVisible').checked = tempMapVisible;
  
  // Redraw the scene
  drawAll();
  
  // Visual feedback
  const resetBtn = document.getElementById('resetMapPosition');
  const originalText = resetBtn.textContent;
  resetBtn.textContent = 'Reset!';
  resetBtn.style.background = 'var(--sepia)';
  resetBtn.style.color = 'var(--paper)';
  
  setTimeout(() => {
    resetBtn.textContent = originalText;
    resetBtn.style.background = 'var(--paper)';
    resetBtn.style.color = 'var(--ink)';
  }, 1500);
  
  console.log('Map reset to origin position');
}

function loadMapSettings() {
  // Load map-specific settings
  const storageKey = 'plateH_map' + currentMapIndex + '_settings';
  const savedSettings = localStorage.getItem(storageKey);
  
  console.log('DEBUG: Loading settings for map index:', currentMapIndex);
  console.log('DEBUG: Storage key:', storageKey);
  console.log('DEBUG: Saved settings found:', !!savedSettings);
  
  if (savedSettings) {
    const mapSettings = JSON.parse(savedSettings);
    console.log('Loading map settings for', MAP_CONFIGS[currentMapIndex].name, ':', mapSettings);
    
    // Apply loaded settings
    tempMapScale = mapSettings.scale || 1.0;
    tempMapRotation = mapSettings.rotation || 0.0;
    tempMapX = mapSettings.x || 0;
    tempMapY = mapSettings.y || 0;
    tempMapVisible = mapSettings.visible !== undefined ? mapSettings.visible : true;
    
    // Update all controls - with debugging and safety checks
    console.log('DEBUG: Updating UI controls with loaded values');
    console.log('DEBUG: tempMapScale =', tempMapScale);
    console.log('DEBUG: tempMapRotation =', tempMapRotation);
    console.log('DEBUG: tempMapX =', tempMapX);
    console.log('DEBUG: tempMapY =', tempMapY);
    
    const scaleSlider = document.getElementById('mapScale');
    const scaleInput = document.getElementById('mapScale-input');
    const scaleOut = document.getElementById('mapScale-out');
    
    if (scaleSlider && scaleInput && scaleOut) {
      scaleSlider.value = tempMapScale;
      scaleInput.value = tempMapScale;
      scaleOut.textContent = tempMapScale.toFixed(2);
      console.log('DEBUG: Updated scale controls to', tempMapScale);
    } else {
      console.log('DEBUG: Scale controls not found in DOM');
    }
    
    const rotSlider = document.getElementById('mapRotation');
    const rotInput = document.getElementById('mapRotation-input');
    const rotOut = document.getElementById('mapRotation-out');
    
    if (rotSlider && rotInput && rotOut) {
      rotSlider.value = tempMapRotation;
      rotInput.value = tempMapRotation;
      rotOut.textContent = tempMapRotation.toFixed(1) + '°';
      console.log('DEBUG: Updated rotation controls to', tempMapRotation);
    } else {
      console.log('DEBUG: Rotation controls not found in DOM');
    }
    
    const xSlider = document.getElementById('mapOffsetX');
    const xInput = document.getElementById('mapOffsetX-input');
    const xOut = document.getElementById('mapOffsetX-out');
    
    if (xSlider && xInput && xOut) {
      xSlider.value = tempMapX;
      xInput.value = tempMapX;
      xOut.textContent = Math.round(tempMapX);
      console.log('DEBUG: Updated X offset controls to', tempMapX);
    } else {
      console.log('DEBUG: X offset controls not found in DOM');
    }
    
    const ySlider = document.getElementById('mapOffsetY');
    const yInput = document.getElementById('mapOffsetY-input');
    const yOut = document.getElementById('mapOffsetY-out');
    
    if (ySlider && yInput && yOut) {
      ySlider.value = tempMapY;
      yInput.value = tempMapY;
      yOut.textContent = Math.round(tempMapY);
      console.log('DEBUG: Updated Y offset controls to', tempMapY);
    } else {
      console.log('DEBUG: Y offset controls not found in DOM');
    }
    
    const visibleCheck = document.getElementById('tempMapVisible');
    if (visibleCheck) {
      visibleCheck.checked = tempMapVisible;
      console.log('DEBUG: Updated visible checkbox to', tempMapVisible);
    } else {
      console.log('DEBUG: Visible checkbox not found in DOM');
    }
    
    // Don't call drawAll here - wait for image to load to avoid BIS initialization issues
    
    // Visual feedback
    const loadBtn = document.getElementById('loadMapPosition');
    const originalText = loadBtn.textContent;
    loadBtn.textContent = 'Loaded!';
    loadBtn.style.background = 'var(--sepia)';
    loadBtn.style.color = 'var(--paper)';
    
    setTimeout(() => {
      loadBtn.textContent = originalText;
      loadBtn.style.background = 'var(--paper)';
      loadBtn.style.color = 'var(--ink)';
    }, 1500);
    
    console.log('Map settings loaded successfully');
  } else {
    console.log('No saved map settings found, using MAP_DEFAULT_POSITIONS fallback');
    
    // Use MAP_DEFAULT_POSITIONS as fallback
    const defaultPosition = MAP_DEFAULT_POSITIONS[currentMapIndex];
    if (defaultPosition) {
      console.log('Applying default position for', MAP_CONFIGS[currentMapIndex].name, ':', defaultPosition);
      
      // Apply default settings
      tempMapScale = defaultPosition.scale || 1.0;
      tempMapRotation = defaultPosition.rotation || 0.0;
      tempMapX = defaultPosition.x || 0;
      tempMapY = defaultPosition.y || 0;
      tempMapOpacity = defaultPosition.opacity || 50;
      tempMapVisible = true;
      
      console.log('Applied fallback settings:', {
        scale: tempMapScale,
        rotation: tempMapRotation,
        x: tempMapX,
        y: tempMapY,
        opacity: tempMapOpacity
      });
      
      // Update UI controls
      const scaleSlider = document.getElementById('mapScale');
      const scaleInput = document.getElementById('mapScale-input');
      const scaleOut = document.getElementById('mapScale-out');
      
      if (scaleSlider && scaleInput && scaleOut) {
        scaleSlider.value = tempMapScale;
        scaleInput.value = tempMapScale;
        scaleOut.textContent = tempMapScale.toFixed(2);
      }
      
      const rotSlider = document.getElementById('mapRotation');
      const rotInput = document.getElementById('mapRotation-input');
      const rotOut = document.getElementById('mapRotation-out');
      
      if (rotSlider && rotInput && rotOut) {
        rotSlider.value = tempMapRotation;
        rotInput.value = tempMapRotation;
        rotOut.textContent = tempMapRotation.toFixed(1) + '°';
      }
      
      const xSlider = document.getElementById('mapOffsetX');
      const xInput = document.getElementById('mapOffsetX-input');
      const xOut = document.getElementById('mapOffsetX-out');
      
      if (xSlider && xInput && xOut) {
        xSlider.value = tempMapX;
        xInput.value = tempMapX;
        xOut.textContent = Math.round(tempMapX);
      }
      
      const ySlider = document.getElementById('mapOffsetY');
      const yInput = document.getElementById('mapOffsetY-input');
      const yOut = document.getElementById('mapOffsetY-out');
      
      if (ySlider && yInput && yOut) {
        ySlider.value = tempMapY;
        yInput.value = tempMapY;
        yOut.textContent = Math.round(tempMapY);
      }
      
      const opacitySlider = document.getElementById('mapOpacity');
      const opacityOut = document.getElementById('mapOpacity-out');
      
      if (opacitySlider && opacityOut) {
        opacitySlider.value = tempMapOpacity;
        opacityOut.textContent = Math.round(tempMapOpacity) + '%';
      }
      
      const visibleCheck = document.getElementById('tempMapVisible');
      if (visibleCheck) {
        visibleCheck.checked = tempMapVisible;
      }
      
      // Visual feedback for fallback applied
      const loadBtn = document.getElementById('loadMapPosition');
      const originalText = loadBtn.textContent;
      loadBtn.textContent = 'Fallback Used';
      loadBtn.style.background = 'var(--sepia)';
      loadBtn.style.color = 'var(--paper)';
      
      setTimeout(() => {
        loadBtn.textContent = originalText;
        loadBtn.style.background = 'var(--paper)';
        loadBtn.style.color = 'var(--ink)';
      }, 1500);
      
      console.log('Map default position applied successfully');
    } else {
      console.log('No default position found for map index:', currentMapIndex);
      
      // Visual feedback for no settings
      const loadBtn = document.getElementById('loadMapPosition');
      const originalText = loadBtn.textContent;
      loadBtn.textContent = 'None Found';
      loadBtn.style.background = 'var(--rust)';
      loadBtn.style.color = 'var(--paper)';
      
      setTimeout(() => {
        loadBtn.textContent = originalText;
        loadBtn.style.background = 'var(--paper)';
        loadBtn.style.color = 'var(--ink)';
      }, 1500);
    }
  }
}

function saveBISDefaults() {
  if (BIS && BIS.getAllBuildings) {
    const currentBuildings = BIS.getAllBuildings();
    const defaults = {};
    
    console.log('Current buildings to save:', currentBuildings);
    
    currentBuildings.forEach(building => {
      console.log(`Saving building ${building.name}:`, building);
      defaults[building.name] = {
        nwCoordinate: { ...building.nwCoordinate },
        dimensions: { ...building.dimensions },
        height: building.height,
        color: building.color,
        type: building.type
      };
      
      // Save church sections if present
      if (building.sections) {
        defaults[building.name].sections = building.sections.map(section => ({ ...section }));
        console.log(`Saved sections for ${building.name}:`, building.sections);
      }
    });
    
    // Save to localStorage
    const defaultsJSON = JSON.stringify(defaults);
    localStorage.setItem('bisDefaults', defaultsJSON);
    console.log('BIS defaults saved to localStorage:', defaults);
    console.log('localStorage size:', defaultsJSON.length);
    
    // Verify save by reading back
    const verifySaved = localStorage.getItem('bisDefaults');
    console.log('Verification - read back from localStorage:', verifySaved);
    
    // Show confirmation
    const bisContent = document.getElementById('bis-content');
    if (bisContent) {
      const confirmation = document.createElement('div');
      confirmation.style.cssText = 'background:var(--sepia);color:var(--paper);padding:0.5rem;text-align:center;margin-bottom:0.5rem;border-radius:3px;font-size:0.6rem;';
      confirmation.textContent = `✓ Saved ${Object.keys(defaults).length} buildings`;
      bisContent.insertBefore(confirmation, bisContent.firstChild);
      setTimeout(() => confirmation.remove(), 3000);
    }
  } else {
    console.error('BIS not available for saving defaults');
  }
}

function loadBISDefaults() {
  const savedDefaults = localStorage.getItem('bisDefaults');
  console.log('loadBISDefaults called. Found saved defaults:', !!savedDefaults);
  
  if (savedDefaults && BIS) {
    try {
      const defaults = JSON.parse(savedDefaults);
      console.log('Loading BIS defaults:', defaults);
      console.log('Number of buildings in defaults:', Object.keys(defaults).length);
      
      // Update each building with saved defaults
      Object.keys(defaults).forEach(buildingName => {
        const defaultData = defaults[buildingName];
        console.log(`Loading ${buildingName}:`, defaultData);
        
        // Update building coordinates and properties
        if (typeof updateBuildingNW === 'function') {
          console.log(`Updating ${buildingName} NW to:`, defaultData.nwCoordinate);
          updateBuildingNW(buildingName, 'x', defaultData.nwCoordinate.x);
          updateBuildingNW(buildingName, 'y', defaultData.nwCoordinate.y);
        }
        
        if (BIS.updateBuildingWDist) {
          console.log(`Updating ${buildingName} WDIST to:`, defaultData.dimensions.width);
          BIS.updateBuildingWDist(buildingName, defaultData.dimensions.width);
        }
        
        if (BIS.updateBuildingNDist) {
          console.log(`Updating ${buildingName} NDIST to:`, defaultData.dimensions.length);
          BIS.updateBuildingNDist(buildingName, defaultData.dimensions.length);
        }
        
        if (BIS.updateBuildingHeight) {
          console.log(`Updating ${buildingName} height to:`, defaultData.height);
          BIS.updateBuildingHeight(buildingName, defaultData.height);
        }
        
        // Update church sections if present
        if (defaultData.sections && BIS.updateChurchSectionHeight) {
          console.log(`Loading ${buildingName} sections:`, defaultData.sections);
          defaultData.sections.forEach(section => {
            console.log(`Updating ${buildingName} section ${section.name} height to:`, section.height);
            BIS.updateChurchSectionHeight(section.name, section.height);
          });
        }
      });
      
      // Update UI to reflect loaded defaults
      if (typeof updateBISDisplay === 'function') {
        updateBISDisplay();
      }
      
      drawAll(); // Redraw with loaded defaults
      console.log('BIS defaults loaded successfully');
      
    } catch (error) {
      console.error('Error loading BIS defaults:', error);
      console.error('Saved defaults string:', savedDefaults);
    }
  } else {
    console.log('No saved defaults found or BIS not available');
  }
}

// Global BIS instance - ensure proper initialization
let BIS;
try {
  BIS = new BuildingInfoSystem();
  console.log('BIS Debug: Successfully initialized');
  
  // Debug: Check NYU Corner immediately after initialization
  setTimeout(() => {
    const nyuCorner = BIS.getBuildingInfo('NYU Corner');
    if (nyuCorner) {
      console.log('NYU Corner after initialization:', nyuCorner);
      console.log('NYU Corner dimensions:', nyuCorner.dimensions);
      console.log('NYU Corner position:', nyuCorner.position);
    } else {
      console.log('NYU Corner not found after initialization!');
    }
  }, 100);
  
  // Load saved defaults after initialization - with delay to ensure BIS is ready
  setTimeout(() => {
    console.log('Attempting to load BIS defaults...');
    loadBISDefaults();
  }, 100);
} catch (error) {
  console.error('BIS Debug: Initialization failed:', error);
  BIS = null;
}

