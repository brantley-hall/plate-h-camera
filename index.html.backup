function getPlanFtW(){return GRID_WIDTH_FT;}
const GRID=100;

// Zoom window: 15 ft wide × 15 ft tall centered on camera (40x plan scale)
const ZOOM_HALF_W=15, ZOOM_HALF_H=15;

// ── State ─────────────────────────────────────────────────────────────────
let camFtX=-125, camFtY=0;
let camRotation=0;
// Plate size state
let currentPlateSize = '2x2.5';
// Occlusion zone state (percentage from bottom)
let occlusionZonePercent = 0;

// Function to handle plate size changes
function changePlateSize(size) {
  console.log('Changing plate size to:', size);
  currentPlateSize = size;
  
  // Update canvas dimensions based on plate size
  updatePlateCanvasSize();
  
  // Update instruction display
  document.getElementById('instr-plate-size').textContent = getDisplayName(size);
  
  // Redraw everything with new plate dimensions
  drawAll();
}

// Function to update plate canvas size based on plate dimensions
function updatePlateCanvasSize() {
  const canvas = document.getElementById('plateStrip');
  console.log('DEBUG: Canvas element found:', !!canvas);
  console.log('DEBUG: Current plate size:', currentPlateSize);
  if (!canvas) {
    console.log('DEBUG: Canvas element not found!');
    return;
  }
  
  const plateWidth = getPlateWidth();
  const plateHeight = getPlateHeight();
  
  // Define reasonable target sizes for each plate format
  // These maintain aspect ratios but are proportional to each other
  let targetWidth, targetHeight;
  
  if (currentPlateSize === 'quarter') {
    targetWidth = 340;  // Width for 260px height at 1.308 aspect ratio (4.25/3.25)
    targetHeight = 260; // Max height 260px
    console.log('DEBUG: Quarter plate selected - setting canvas to', targetWidth, 'x', targetHeight);
    
    // Force complete canvas reinitialization for quarter plate
    console.log('DEBUG: Forcing canvas reinitialization for quarter plate');
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    canvas.width = 0;
    canvas.height = 0;
    canvas.width = targetWidth;
    canvas.height = targetHeight;
  } else if (currentPlateSize === '2x2.5') {
    targetWidth = 320;  // Width for 400px height at 0.8 aspect ratio
    targetHeight = 400; // Max height 400px
  } else if (currentPlateSize === '5x7-portrait') {
    targetWidth = 300;  // Scaled for 420px height (5/7 aspect ratio)
    targetHeight = 420; // Max height 420px
  } else if (currentPlateSize === '5x7-landscape') {
    targetWidth = 420;  // Scaled for 420px width (7/5 aspect ratio)
    targetHeight = 300; // Corresponding height for 7/5 aspect ratio
  } else if (currentPlateSize === '8x10-portrait') {
    targetWidth = 336;  // Scaled for 420px height (8/10 aspect ratio)
    targetHeight = 420; // Max height 420px
  } else if (currentPlateSize === '8x10-landscape') {
    targetWidth = 420;  // Scaled for 420px width (10/8 aspect ratio)
    targetHeight = 336; // Corresponding height for 10/8 aspect ratio
  } else {
    // Fallback
    targetWidth = 400;
    targetHeight = 500;
  }
  
  // Update canvas size
  canvas.width = targetWidth;
  canvas.height = targetHeight;
  
  // Update CSS display size
  canvas.style.width = targetWidth + 'px';
  canvas.style.height = targetHeight + 'px';
  
  console.log('DEBUG: Canvas updated to', targetWidth, 'x', targetHeight);
  console.log('DEBUG: Canvas.width =', canvas.width, 'Canvas.height =', canvas.height);
  
  // Update plate border to fit exactly around canvas
  const plateBorder = canvas.parentElement;
  if (plateBorder && plateBorder.classList.contains('plate-border')) {
    plateBorder.style.width = (targetWidth + 12) + 'px'; // 6px padding + 6px border (3px each side)
    plateBorder.style.height = (targetHeight + 12) + 'px'; // 6px padding + 6px border (3px each side)
    console.log('Updated plate border to fit canvas: ' + (targetWidth + 12) + 'x' + (targetHeight + 12) + 'px');
    console.log('DEBUG: Border element found:', plateBorder);
    console.log('DEBUG: Border computed width:', plateBorder.offsetWidth);
    console.log('DEBUG: Border computed height:', plateBorder.offsetHeight);
    console.log('DEBUG: Border style width:', plateBorder.style.width);
    console.log('DEBUG: Border style height:', plateBorder.style.height);
  } else {
    console.log('DEBUG: Plate border element not found or does not have plate-border class');
    console.log('DEBUG: Canvas parent element:', canvas.parentElement);
    console.log('DEBUG: Canvas parent classes:', canvas.parentElement ? canvas.parentElement.className : 'null');
  }
  
  console.log(`CANVAS SIZING DEBUG:`);
  console.log(`- Target size: ${targetWidth}x${targetHeight}`);
  console.log(`- Canvas.width: ${canvas.width}`);
  console.log(`- Canvas.height: ${canvas.height}`);
  console.log(`- Canvas.style.width: ${canvas.style.width}`);
  console.log(`- Canvas.style.height: ${canvas.style.height}`);
  console.log(`- Canvas.offsetWidth: ${canvas.offsetWidth}`);
  console.log(`- Canvas.offsetHeight: ${canvas.offsetHeight}`);
  
  // Update overlay to fit properly within the plate border
  const overlay = document.getElementById('dagOverlay');
  if (overlay) {
    // For 2x2.5 plate, ensure overlay stays completely within frame
    if (currentPlateSize === '2x2.5') {
      overlay.style.width = `calc(100% - 12px)`; // Leave more space to prevent peeking
      overlay.style.height = `calc(100% - 12px)`; // Leave more space to prevent peeking
      overlay.style.top = '6px'; // Position further from edge
      overlay.style.left = '6px'; // Position further from edge
      overlay.style.objectFit = 'cover'; // Fill entire canvas
      console.log('DEBUG: 2x2.5 overlay positioned to prevent peeking');
    } else {
      overlay.style.width = `calc(100% - 6px)`;
      overlay.style.height = `calc(100% - 6px)`;
      overlay.style.top = '3px';
      overlay.style.left = '3px';
      overlay.style.objectFit = 'contain'; // Default behavior for other plates
    }
    
    console.log(`DEBUG: Updated overlay for ${currentPlateSize} - size: ${targetWidth}x${targetHeight}`);
  }
  
  // Force overlay repositioning with a small delay to ensure DOM updates
  setTimeout(() => {
    const overlayCheck = document.getElementById('dagOverlay');
    if (overlayCheck) {
      // Apply the same positioning logic as above
      if (currentPlateSize === '2x2.5') {
        overlayCheck.style.width = `calc(100% - 12px)`;
        overlayCheck.style.height = `calc(100% - 12px)`;
        overlayCheck.style.top = '6px';
        overlayCheck.style.left = '6px';
        overlayCheck.style.objectFit = 'cover';
      } else {
        overlayCheck.style.width = `calc(100% - 6px)`;
        overlayCheck.style.height = `calc(100% - 6px)`;
        overlayCheck.style.top = '3px';
        overlayCheck.style.left = '3px';
        overlayCheck.style.objectFit = 'contain';
      }
      
      console.log(`DEBUG: Force updated overlay positioning for ${currentPlateSize}`);
    }
  }, 50);
  
  console.log(`Updated canvas size to ${targetWidth}x${targetHeight} for plate ${plateWidth}x${plateHeight} (aspect ratio: ${(plateWidth/plateHeight).toFixed(2)})`);
  console.log(`DEBUG: Canvas actual size: ${canvas.width}x${canvas.height}, CSS size: ${canvas.style.width}x${canvas.style.height}`);
  
  // Force a redraw and then update the plate title
  setTimeout(() => {
    updatePlateTitle();
    const computedWidth = canvas.offsetWidth;
    const computedHeight = canvas.offsetHeight;
    console.log(`DEBUG: Computed canvas size after update: ${computedWidth}x${computedHeight}`);
  }, 50);
}

// Function to get display name for plate size
function getDisplayName(size) {
  const names = {
    'quarter': '4.25×3.25',
    '2x2.5': '2×2.5',
    '5x7-portrait': '5×7 Portrait',
    '5x7-landscape': '5×7 Landscape',
    '8x10-portrait': '8×10 Portrait',
    '8x10-landscape': '8×10 Landscape'
  };
  return names[size] || size;
}

// Overlay image configuration
const OVERLAY_IMAGES = {
  'PlateH': {
    name: 'Plate H',
    filename: 'PlateH.png',
    alt: 'Plate H overlay'
  },
  'KingsHandbook1893': {
    name: "NYU Collection 1893",
    filename: '1890 NYU Archive.jpg',
    alt: "NYU Collection 1893 overlay"
  },
  'KingsHandbookNYU': {
    name: "NYU Collection",
    filename: 'Kings Handbook NYU.jpg',
    alt: "NYU Collection overlay"
  },
  'NYUCollection1870': {
    name: "NYU Collection 1870",
    filename: '1870 NYU Collection.jpg',
    alt: "NYU Collection 1870 overlay"
  },
  'NYUCollection1891': {
    name: "NYU Collection 1891",
    filename: '1891 NYU Collection.jpg',
    alt: "NYU Collection 1891 overlay"
  },
  'Austen1894': {
    name: "Austen 1894",
    filename: 'Austen 1894.jpg',
    alt: "Austen 1894 overlay"
  },
  'Smithsonian1839': {
    name: "1839 Smithsonian",
    filename: '1839ChurchofMessiahSmithsonian.jpg',
    alt: "1839 Smithsonian Church of Messiah overlay"
  }
};

// Current overlay selection
let currentOverlayImage = 'PlateH';

// Function to toggle overlay selection
function toggleOverlaySelection() {
  // Cycle through overlay options
  const overlayTypes = Object.keys(OVERLAY_IMAGES);
  const currentIndex = overlayTypes.indexOf(currentOverlayImage);
  const nextIndex = (currentIndex + 1) % overlayTypes.length;
  const nextOverlayType = overlayTypes[nextIndex];
  
  changeOverlayImage(nextOverlayType);
  
  // Update button text to show current selection
  const overlayButton = document.getElementById('overlay-toggle');
  if (overlayButton && OVERLAY_IMAGES[nextOverlayType]) {
    let shortName;
    if (nextOverlayType === 'PlateH') {
      shortName = 'PLATE H';
    } else if (nextOverlayType === 'NYUCollection1870') {
      shortName = '1870';
    } else if (nextOverlayType === 'NYUCollection1891') {
      shortName = '1891';
    } else if (nextOverlayType === 'Austen1894') {
      shortName = 'AUSTEN';
    } else if (nextOverlayType === 'Smithsonian1839') {
      shortName = '1839';
    } else {
      shortName = "KING'S";
    }
    overlayButton.textContent = shortName;
    console.log(`Updated overlay button text to: ${shortName}`);
  }
}

// Function to switch overlay (like switchMap)
function switchOverlay(overlayType) {
  currentOverlayImage = overlayType;
  
  // Update overlay image
  const overlay = document.getElementById('dagOverlay');
  if (overlay && OVERLAY_IMAGES[overlayType]) {
    const overlayConfig = OVERLAY_IMAGES[overlayType];
    overlay.src = overlayConfig.filename;
    overlay.alt = overlayConfig.alt;
    console.log(`Updated overlay to ${overlayConfig.name} (${overlayConfig.filename})`);
  }
  
  // Update viewfinder overlay name display
  const viewfinderOverlayNameSpan = document.getElementById('viewfinder-overlay-name');
  if (viewfinderOverlayNameSpan && OVERLAY_IMAGES[overlayType]) {
    viewfinderOverlayNameSpan.textContent = OVERLAY_IMAGES[overlayType].name;
  }
}

// Function to toggle overlay selector popup
function toggleOverlaySelector() {
  const display = document.getElementById('overlay-selector-display');
  const button = document.getElementById('overlay-selector-toggle');
  if (display && button) {
    const isVisible = display.style.display !== 'none';
    display.style.display = isVisible ? 'none' : 'block';
    
    if (isVisible) {
      button.textContent = 'OVERLAY';
      button.style.background = 'var(--paper)';
      button.style.color = 'var(--ink)';
    } else {
      button.textContent = 'Exit Overlay';
      button.style.background = 'var(--rust)';
      button.style.color = 'var(--paper)';
    }
    
    console.log('Overlay selector popup ' + (isVisible ? 'hidden' : 'shown'));
  }
}

// Function to select overlay from thumbnail
function selectOverlay(overlayType) {
  switchOverlay(overlayType);
  
  // Hide the popup after selection and reset button text
  const display = document.getElementById('overlay-selector-display');
  const button = document.getElementById('overlay-selector-toggle');
  if (display) {
    display.style.display = 'none';
  }
  if (button) {
    button.textContent = 'OVERLAY';
  }
  
  console.log('Selected overlay: ' + overlayType);
}

// Function to change overlay image (legacy)
function changeOverlayImage(overlayType) {
  switchOverlay(overlayType);
}

// Function to initialize overlay object-fit based on current plate size
function initializeOverlayFit() {
  const overlay = document.getElementById('dagOverlay');
  if (overlay) {
    if (currentPlateSize === '2x2.5') {
      overlay.style.objectFit = 'cover'; // Fill entire canvas
      console.log('DEBUG: Initialized 2x2.5 overlay to cover entire canvas');
    } else {
      overlay.style.objectFit = 'contain'; // Default behavior for other plates
      console.log('DEBUG: Initialized overlay to contain for ' + currentPlateSize);
    }
  }
}

// Function to update plate title
function updatePlateTitle() {
  const titleElement = document.getElementById('plate-title');
  if (titleElement) {
    const displayName = getDisplayName(currentPlateSize);
    const orientation = currentPlateSize.includes('portrait') ? 'portrait' : 
                    (currentPlateSize.includes('landscape') ? 'landscape' : 
                     (currentPlateSize === 'quarter' ? 'landscape' : 'portrait'));
    
    // Get actual canvas dimensions
    const canvas = document.getElementById('plateStrip');
    const canvasWidth = canvas ? canvas.width : 0;
    const canvasHeight = canvas ? canvas.height : 0;
    
    titleElement.textContent = `${displayName} inch plate (${canvasWidth}×${canvasHeight}px) — ${orientation}`;
  }
}

function clampCam(){
  camFtX=Math.round(Math.max(GRID_X_MIN,Math.min(GRID_X_MAX,camFtX)));
  camFtY=Math.round(Math.max(GRID_Y_MIN,Math.min(GRID_Y_MAX,camFtY)));
}
clampCam();

// ── Layout setup ──────────────────────────────────────────────────────────
function setup(){
  const planCol = plan.parentElement;
  const W = planCol.offsetWidth || 700;
  plan.width = W;
  plan.height = Math.round(W * 0.375); // Reduced from 0.5 to 0.375 (25% reduction)
  
  // Initialize plateStrip canvas based on current plate size
  updatePlateCanvasSize();
  
  // Initialize instruction spans with current focal length values
  const focalLength = parseFloat(document.getElementById('focal').value);
  const plateWidthInches = getPlateWidth();
  const plateHeightInches = getPlateHeight();
  const fovRad = 2 * Math.atan(plateWidthInches / (2 * focalLength));
  const fovDeg = fovRad * 180 / Math.PI;
  const vFovDeg = fovDeg * (plateHeightInches/plateWidthInches);
  
  document.getElementById('instr-focal').textContent = focalLength + '"';
  document.getElementById('instr-hfov').textContent = fovDeg.toFixed(1) + '°';
  document.getElementById('instr-vfov').textContent = vFovDeg.toFixed(1) + '°';
  document.getElementById('instr-plate-size').textContent = currentPlateSize;
  
  drawAll();
}

function planScale(){return(plan.width-10)/getPlanFtW();}

// Plan pixel coords of grid origin (0,0 at center of grid)
function planOrigin(){
  const s=planScale();
  // Center the grid: origin (0,0) is at grid center, not ZZZ NW corner
  // Grid spans from -300 to +1000 in X, so center is at (X_MIN + X_MAX)/2 = 350
  // But we want (0,0) at actual coordinate origin, so offset by X_MIN
  const gridOffsetX = -GRID_X_MIN * s; // Offset to make (0,0) visible
  return{x:Math.round(gridOffsetX)+5, y:Math.round(plan.height*0.45)};
}



// ── Slider wiring ─────────────────────────────────────────────────────────
document.getElementById('focal').addEventListener('input',e=>{
  const focalLength=parseFloat(e.target.value);
  document.getElementById('focal-out').textContent=focalLength+'"';
  
  // Calculate FOV from focal length: FOV = 2 * arctan(width/(2*focal_length))
  const plateWidthInches = getPlateWidth();
  const plateHeightInches = getPlateHeight();
  const fovRad = 2 * Math.atan(plateWidthInches / (2 * focalLength));
  const fovDeg = fovRad * 180 / Math.PI;
  const vFovDeg = fovDeg * (plateHeightInches/plateWidthInches); // aspect ratio
  
  document.getElementById('fov-out').textContent=fovDeg.toFixed(1)+'°';
  document.getElementById('vfov-out').textContent=vFovDeg.toFixed(1)+'°';
  
  // GEOMETRICALLY CORRECT FOCAL LENGTH BEHAVIOR:
  // When focal length changes, recalculate camera distance to maintain apparent object size
  // scalingFactor = newFocalLength / oldFocalLength
  const oldFocalLength = previousFOV ? (plateWidthInches / (2 * Math.tan(previousFOV * Math.PI / 180))) : 8.0;
  const scalingFactor = focalLength / oldFocalLength;
  
  // Calculate new camera distance proportionally from current position
  const currentDistance = Math.abs(camFtX);
  const newDistance = currentDistance * scalingFactor;
  
  // Update camera X position (distance from buildings)
  camFtX = -Math.abs(newDistance); // Keep negative (west of buildings)
  
  // Update camera position display
  document.getElementById('camX-out').textContent = Math.abs(newDistance).toFixed(0);
  
  // Update instruction spans with current values
  document.getElementById('instr-focal').textContent=focalLength+'"';
  document.getElementById('instr-hfov').textContent=fovDeg.toFixed(1)+'°';
  document.getElementById('instr-vfov').textContent=vFovDeg.toFixed(1)+'°';
  document.getElementById('instr-plate-size').textContent=currentPlateSize;
  
  // Store current FOV for next change
  previousFOV = fovDeg;
  
  // Update coordinates and redraw
  clampCam(); 
  updateCoords(); 
  drawAll();});

// Store previous FOV for proportional scaling
let previousFOV = 15; // Start with default FOV

// FOV slider event listener
document.getElementById('fov-slider').addEventListener('input',e=>{
  console.log('FOV slider input event triggered');
  const fovDeg=parseFloat(e.target.value);
  console.log('FOV value:', fovDeg);
  document.getElementById('fov-slider-out').textContent=fovDeg+'°';
  
  // Calculate focal length from FOV: focal_length = width / (2 * tan(FOV/2))
  const plateWidthInches = getPlateWidth();
  const plateHeightInches = getPlateHeight();
  const fovRad = fovDeg * Math.PI / 180;
  const focalLength = plateWidthInches / (2 * Math.tan(fovRad / 2));
  
  // Update focal length display (read-only in FOV mode)
  document.getElementById('focal-out').textContent=focalLength.toFixed(1)+'"';
  
  // Update FOV displays
  const vFovDeg = fovDeg * (plateHeightInches/plateWidthInches); // aspect ratio
  document.getElementById('fov-out').textContent=fovDeg.toFixed(1)+'°';
  document.getElementById('vfov-out').textContent=vFovDeg.toFixed(1)+'°';
  
  // GEOMETRICALLY CORRECT FOV BEHAVIOR:
  // When FOV changes, recalculate camera distance to maintain apparent object size
  // scalingFactor = tan(oldFOV/2) / tan(newFOV/2)
  const oldFovRad = previousFOV * Math.PI / 180;
  const newFovRad = fovDeg * Math.PI / 180;
  const scalingFactor = Math.tan(oldFovRad / 2) / Math.tan(newFovRad / 2);
  
  // Calculate new camera distance proportionally from current position
  const currentDistance = Math.abs(camFtX);
  const newDistance = currentDistance * scalingFactor;
  
  // Update camera X position (distance from buildings)
  camFtX = -Math.abs(newDistance); // Keep negative (west of buildings)
  
  // Update camera position display
  const camXOut = document.getElementById('camX-out');
  if (camXOut) {
    camXOut.textContent = Math.abs(newDistance).toFixed(0);
  }
  
  // Update instruction spans with current values
  document.getElementById('instr-focal').textContent=focalLength.toFixed(1)+'"';
  document.getElementById('instr-hfov').textContent=fovDeg.toFixed(1)+'°';
  document.getElementById('instr-vfov').textContent=vFovDeg.toFixed(1)+'°';
  document.getElementById('instr-plate-size').textContent=currentPlateSize;
  
  // Store current FOV for next change
  previousFOV = fovDeg;
  
  // Update coordinates and redraw
  clampCam(); 
  updateCoords(); 
  drawAll();
});


// Mode toggle event listeners
function updateModeDisplay() {
  const isFovMode = document.getElementById('fov-mode').checked;
  const isCameraMode = document.getElementById('camera-mode').checked;
  
  document.getElementById('fov-controls').style.display = isFovMode ? 'block' : 'none';
  document.getElementById('camera-controls').style.display = isCameraMode ? 'block' : 'none';
  
  drawAll();
}

// Initialize mode display
document.addEventListener('DOMContentLoaded', function() {
  console.log('DOM loaded - checking FOV elements');
  const fovSlider = document.getElementById('fov-slider');
  const fovControls = document.getElementById('fov-controls');
  const fovMode = document.getElementById('fov-mode');
  
  console.log('FOV slider element:', fovSlider);
  console.log('FOV controls element:', fovControls);
  console.log('FOV mode element:', fovMode);
  console.log('FOV mode checked:', fovMode ? fovMode.checked : 'not found');
  console.log('FOV controls display:', fovControls ? fovControls.style.display : 'not found');
  
  updateModeDisplay();
  initializeOverlayFit(); // Initialize overlay object-fit for 2x2.5 plate
});

document.getElementById('fov-mode').addEventListener('change', updateModeDisplay);
document.getElementById('fov-mode').addEventListener('click', updateModeDisplay);

document.getElementById('camera-mode').addEventListener('change', updateModeDisplay);
document.getElementById('camera-mode').addEventListener('click', updateModeDisplay);

document.getElementById('rotation').addEventListener('input',e=>{
  const rotationValue = parseFloat(e.target.value);
  document.getElementById('rot-out').textContent=rotationValue.toFixed(1)+'°'; 
  document.getElementById('rotation-input').value = rotationValue;
  camRotation = rotationValue; 
  drawAll();
});

// Function to handle rotation input from number field
function updateRotationFromInput() {
  const rotationInput = document.getElementById('rotation-input');
  const rotationSlider = document.getElementById('rotation');
  const rotationValue = parseFloat(rotationInput.value);
  
  // Validate rotation value
  if (rotationValue >= -180 && rotationValue <= 180) {
    camRotation = rotationValue;
    rotationSlider.value = rotationValue;
    document.getElementById('rot-out').textContent = rotationValue.toFixed(1) + '°';
    drawAll();
  }
}
let cameraTiltUp = 0; // Global variable for camera tilt in radians (always 0)
let cameraHeight = 5; // Global variable for camera height in feet

// Camera position function (input only)
function updateCameraFromInput() {
  console.log('updateCameraFromInput called');
  
  // Update from number inputs
  const camXInput = document.getElementById('camX-input');
  const camYInput = document.getElementById('camY-input');
  
  console.log('camXInput:', camXInput, 'camYInput:', camYInput);
  
  if (!camXInput || !camYInput) {
    console.log('Input elements not found');
    return;
  }
  
  const newX = parseFloat(camXInput.value);
  const newY = parseFloat(camYInput.value);
  
  console.log('New values - X:', newX, 'Y:', newY);
  
  // Validate and update camera position
  if (newX >= -400 && newX <= 400) {
    camFtX = newX;
    console.log('Updated camFtX to:', camFtX);
  }
  if (newY >= -400 && newY <= 400) {
    camFtY = newY;
    console.log('Updated camFtY to:', camFtY);
  }
  
  console.log('Before clampCam - camFtX:', camFtX, 'camFtY:', camFtY);
  clampCam(); 
  console.log('After clampCam - camFtX:', camFtX, 'camFtY:', camFtY);
  updateCoords(); 
  drawAll();
  console.log('updateCameraFromInput completed');
}

