      {x: 0, y: 0},        // Southeast corner (where Waverly Place ends at origin)
      {x: 0, y: 60},       // Northeast corner (60 ft wide, same Y as Waverly Place)
      {x: -300, y: 60}     // Northwest corner (60 ft wide, end of screen to west)
    ],
    color: 'rgba(205,133,63,0.8)',  // Clay-colored roadways
    height: ROAD_HEIGHT_FT,  // Add height property for ray-casting
    showLabel: true,
    labelRotation: 0  // Horizontal text for east-west road
  },
  // Greene Street - 40 ft wide road at x=208, runs entire screen height
  {
