function updateCoords(){
  // Calculate distance from camera's current position (0,0 reference)
  const absX = Math.abs(camFtX);
  const absY = Math.abs(camFtY);
  
  const xDirection = camFtX < 0 ? 'West' : 'East';
  const yDirection = camFtY < 0 ? 'South' : 'North';
  
  const descriptiveText = `${absX} ${xDirection} and ${absY} ${yDirection} of origin`;
  const coordText = `(${camFtX}, ${camFtY>0?'+':''}${camFtY}) ft`;
  
  document.getElementById('coords').textContent = descriptiveText;
  document.getElementById('zoom-coord').textContent = coordText;
  
  // Update camera inputs to match current position
  document.getElementById('camX-input').value = Math.round(camFtX);
  document.getElementById('camY-input').value = Math.round(camFtY);
}

// ── Road System Functions ─────────────────────────────────────────────────

function drawRoadSegments(ctx, scale, originX, originY) {
  ctx.save();
  
  roadSegments.forEach(segment => {
    // Draw road polygon with 20% fill opacity and 100% stroke opacity
    const fillColor = segment.color.replace(/[\d.]+\)$/, '0.2)');  // Change opacity to 20%
    const strokeColor = segment.color.replace(/[\d.]+\)$/, '1)');   // Change opacity to 100%
    ctx.fillStyle = fillColor;
    ctx.strokeStyle = strokeColor;
    ctx.lineWidth = 2;
    
    ctx.beginPath();
    segment.corners.forEach((corner, index) => {
      const px = originX + corner.x * scale;
      const py = originY - corner.y * scale; // Y is flipped
      
      if (index === 0) {
        ctx.moveTo(px, py);
      } else {
        ctx.lineTo(px, py);
      }
    });
    ctx.closePath();
    ctx.fill();
    ctx.stroke();
    
    // Draw road name if enabled
    if (segment.showLabel && segment.name) {
      // Calculate center point for label placement
      const centerX = segment.corners.reduce((sum, c) => sum + c.x, 0) / segment.corners.length;
      const centerY = segment.corners.reduce((sum, c) => sum + c.y, 0) / segment.corners.length;
      
      const labelX = originX + centerX * scale;
      const labelY = originY - centerY * scale; // Y is flipped
      
      ctx.fillStyle = 'rgba(0,0,0,0.8)';
      ctx.font = '10px "Source Code Pro", monospace';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      
      // Apply rotation if specified
      if (segment.labelRotation) {
        ctx.save();
        ctx.translate(labelX, labelY);
        ctx.rotate(segment.labelRotation * Math.PI / 180);
        ctx.fillText(segment.name, 0, 0);
        ctx.restore();
      } else {
        ctx.fillText(segment.name, labelX, labelY);
      }
    }
  });
  
  ctx.restore();
}

function getRoadBuildings() {
  const buildings = [];
  
  roadSegments.forEach(segment => {
    // Convert road segment to AABB for ray-casting
    const minX = Math.min(...segment.corners.map(c => c.x));
    const maxX = Math.max(...segment.corners.map(c => c.x));
    const minY = Math.min(...segment.corners.map(c => c.y));
    const maxY = Math.max(...segment.corners.map(c => c.y));
    
    buildings.push({
      x0: minX,
      x1: maxX,
      y0: minY,
      y1: maxY,
      h: segment.height,
      col: segment.color,
      name: segment.name || 'Custom Road'
    });
  });
  
  return buildings;
}


// ── Cursor position tracking ─────────────────────────────────────────────────
let cursorFtX = 0, cursorFtY = 0;

function updateCursorPosition(pixelX, pixelY) {
  const s = planScale();
  const {x: ox, y: oy} = planOrigin();
  
  // Convert pixel coordinates to world coordinates (feet)
  // World coordinates: X east, Y north, origin at (0,0)
  cursorFtX = (pixelX - ox) / s;
  cursorFtY = -(pixelY - oy) / s; // Y is flipped in canvas coordinates
  
  // Update cursor position display
  const cursorDisplay = document.getElementById('cursor-position');
  if (cursorDisplay) {
    cursorDisplay.textContent = `Cursor: (${Math.round(cursorFtX)}, ${cursorFtY >= 0 ? '+' : ''}${Math.round(cursorFtY)}) ft`;
  }
}

// ── Tape measure helper functions ─────────────────────────────────────────
function pxToWorld(pixelX, pixelY) {
  const s = planScale();
  const {x: ox, y: oy} = planOrigin();
  
  // Convert pixel coordinates to world coordinates (feet)
  // World coordinates: X east, Y north, origin at (0,0)
  const worldX = (pixelX - ox) / s;
  const worldY = -(pixelY - oy) / s; // Y is flipped in canvas coordinates
  
  return {x: worldX, y: worldY};
}

function worldToPx(worldX, worldY) {
  const s = planScale();
  const {x: ox, y: oy} = planOrigin();
  
  // Convert world coordinates to pixel coordinates
  // World coordinates: X east, Y north, origin at (0,0)
  const pixelX = ox + worldX * s;
  const pixelY = oy - worldY * s; // Y is flipped in canvas coordinates
  
  return {x: pixelX, y: pixelY};
}

function calculateDistance(start, end) {
  const dx = end.x - start.x;
  const dy = end.y - start.y;
  return Math.sqrt(dx * dx + dy * dy);
}

function updateTapeMeasureDisplay() {
  const display = document.getElementById('tape-measure-display');
  if (!display) return;
  
  if (tapeMeasureStart && tapeMeasureEnd) {
    const distance = calculateDistance(tapeMeasureStart, tapeMeasureEnd);
    const dx = tapeMeasureEnd.x - tapeMeasureStart.x;
    const dy = tapeMeasureEnd.y - tapeMeasureStart.y;
    
    display.innerHTML = `
      <div style="font-family:'Source Code Pro',monospace;font-size:0.6rem;color:var(--sepia);">
        Distance: <span style="color:var(--rust);font-weight:700;">${distance.toFixed(1)} ft</span><br>
        ΔX: <span style="color:var(--ink);">${dx >= 0 ? '+' : ''}${dx.toFixed(1)} ft</span><br>
        ΔY: <span style="color:var(--ink);">${dy >= 0 ? '+' : ''}${dy.toFixed(1)} ft</span>
      </div>
    `;
  } else {
    display.innerHTML = `
      <div style="font-family:'Source Code Pro',monospace;font-size:0.6rem;color:var(--muted);">
        Click and drag to measure
      </div>
    `;
  }
}

function toggleTapeMeasureMode() {
  tapeMeasureMode = !tapeMeasureMode;
  const button = document.getElementById('tape-measure-toggle');
  const display = document.getElementById('tape-measure-display');
  
  if (tapeMeasureMode) {
    button.textContent = 'Exit Tape Measure';
    button.style.background = 'var(--rust)';
    button.style.color = 'var(--paper)';
    display.style.display = 'block';
    updateTapeMeasureDisplay();
  } else {
    button.textContent = 'Tape Measure';
    button.style.background = 'var(--paper)';
    button.style.color = 'var(--ink)';
    display.style.display = 'none';
    // Clear tape measure
    tapeMeasureStart = null;
    tapeMeasureEnd = null;
    tapeMeasureActive = false;
    drawAll();
  }
}

// ── Plan canvas drag ───────────────────────────────────────────────────────
// ── Plan drag — move camera in main plan view ───────────────────────────────
// The plan canvas uses planScale(), so 1 ft = planScale() px on plan canvas.
// Camera moves in variable increments (1 ft or 2 ft).
let pDrag=false;
let pLastPx=0, pLastPy=0;

// ── Site Scene functionality ─────────────────────────────────────────────
let siteSceneMode=false;

function toggleSiteScene() {
  const display = document.getElementById('site-scene-selector-display');
  const button = document.getElementById('site-scene-toggle');
  
  if (display && button) {
    const isVisible = display.style.display !== 'none';
    display.style.display = isVisible ? 'none' : 'block';
    
    if (isVisible) {
      button.textContent = 'SITE SCENE';
      button.style.background = 'var(--paper)';
      button.style.color = 'var(--ink)';
    } else {
      button.textContent = 'Exit Site Scene';
      button.style.background = 'var(--rust)';
      button.style.color = 'var(--paper)';
    }
    
    console.log('Site Scene selector popup ' + (isVisible ? 'hidden' : 'shown'));
  }
}

function selectSiteScene(mapIndex) {
  // Set the selected map index
  currentMapIndex = mapIndex;
  
  // Save the selection to localStorage
  localStorage.setItem('plateH_selectedMap', mapIndex.toString());
  
  // Load the selected map directly without calling getSelectedMapIndex
  const config = MAP_CONFIGS[currentMapIndex];
  
  console.log('DEBUG: selectSiteScene called');
  console.log('DEBUG: currentMapIndex:', currentMapIndex);
  console.log('DEBUG: config:', config);
  console.log('Loading map:', config.name);
  console.log('File:', config.filename);
  
  mapLoadAttempted = false;
  
  // Store existing onload handler if it exists
  const originalOnload = _mapImg.onload;
  
  // Set new onload handler that loads settings and calls original handler
  _mapImg.onload = function() {
    console.log('Map loaded, now loading saved settings for:', config.name);
    loadMapSettings();
    updateMapPosition(); // Apply the loaded settings
    
    // Call original onload handler if it existed
    if (originalOnload) {
      originalOnload.call(this);
    }
  };
  
  _mapImg.src = config.filename;
  
  // Update the map selector dropdown
  updateMapSelector();
  
  // Update the site plan callout
  const sitePlanMapNameSpan = document.getElementById('site-plan-map-name');
  if (sitePlanMapNameSpan && MAP_CONFIGS[currentMapIndex]) {
    sitePlanMapNameSpan.textContent = MAP_CONFIGS[currentMapIndex].name;
  }
  
  // Hide the popup after selection and reset button text
  const display = document.getElementById('site-scene-selector-display');
  const button = document.getElementById('site-scene-toggle');
  if (display) {
    display.style.display = 'none';
  }
  if (button) {
    button.textContent = 'SITE SCENE';
    button.style.background = 'var(--paper)';
    button.style.color = 'var(--ink)';
  }
  
  console.log('Selected site scene map:', MAP_CONFIGS[mapIndex].name);
}

function toggleHelp() {
  const display = document.getElementById('help-display');
  const button = document.getElementById('help-toggle');
  
  if (display && button) {
    const isVisible = display.style.display !== 'none';
    display.style.display = isVisible ? 'none' : 'block';
    
    if (isVisible) {
      button.textContent = 'HELP';
      button.style.background = 'var(--paper)';
      button.style.color = 'var(--ink)';
    } else {
      button.textContent = 'Exit Help';
      button.style.background = 'var(--rust)';
      button.style.color = 'var(--paper)';
    }
    
    console.log('Help display ' + (isVisible ? 'hidden' : 'shown'));
  }
}

// ── Tape measure functionality ───────────────────────────────────────────
let tapeMeasureMode=false;
let tapeMeasureStart=null;
let tapeMeasureEnd=null;
let tapeMeasureActive=false;

function getPP(e){
  const r=plan.getBoundingClientRect(), s=plan.width/r.width;
  const src=e.touches?e.touches[0]:e;
  return{x:(src.clientX-r.left)*s, y:(src.clientY-r.top)*s};
}

plan.addEventListener('mousedown',e=>{
  if(tapeMeasureMode){
    // Start tape measure
    const p=getPP(e);
    const worldPos=pxToWorld(p.x, p.y);
    tapeMeasureStart=worldPos;
    tapeMeasureEnd=worldPos;
    tapeMeasureActive=true;
    updateTapeMeasureDisplay();
    drawAll();
  } else {
    // Normal camera drag
    pDrag=true;
    const p=getPP(e); pLastPx=p.x; pLastPy=p.y;
  }
});
plan.addEventListener('mousemove',e=>{
  const p=getPP(e);
  // Update cursor position regardless of drag state
  updateCursorPosition(p.x, p.y);
  
  if(tapeMeasureMode && tapeMeasureActive){
    // Update tape measure end point
    const worldPos=pxToWorld(p.x, p.y);
    tapeMeasureEnd=worldPos;
    updateTapeMeasureDisplay();
    drawAll();
  } else if(!pDrag){
    return;
  } else {
    // Normal camera drag
    const ps=planScale();
    const dFtX=Math.round((p.x-pLastPx)/ps/1)*1; // Fixed 1-foot increments
    const dFtY=Math.round(-(p.y-pLastPy)/ps/1)*1; // Fixed 1-foot increments
    if(dFtX!==0||dFtY!==0){
      camFtX=Math.max(GRID_X_MIN,Math.min(GRID_X_MAX, camFtX+dFtX));
      camFtY=Math.max(GRID_Y_MIN,Math.min(GRID_Y_MAX,camFtY+dFtY));
      pLastPx=p.x; pLastPy=p.y;
      clampCam(); updateCoords(); drawAll();
    }
  }
});
plan.addEventListener('mouseup',()=>{
  if(tapeMeasureMode){
    tapeMeasureActive=false;
  } else {
    pDrag=false;
  }
});
plan.addEventListener('mouseleave',()=>{
  pDrag=false;
  // Clear cursor position when mouse leaves canvas
  const cursorDisplay = document.getElementById('cursor-position');
  if (cursorDisplay) {
    cursorDisplay.textContent = 'Cursor: (---, ---) ft';
  }
});
plan.addEventListener('touchstart',e=>{
  e.preventDefault(); pDrag=true;
  const p=getPP(e); pLastPx=p.x; pLastPy=p.y;
},{passive:false});
plan.addEventListener('touchmove',e=>{
  e.preventDefault(); if(!pDrag)return;
  const p=getPP(e);
  const ps=planScale();
  const dFtX=Math.round((p.x-pLastPx)/ps/1)*1; // Fixed 1-foot increments
  const dFtY=Math.round(-(p.y-pLastPy)/ps/1)*1; // Fixed 1-foot increments 
  if(dFtX!==0||dFtY!==0){
    camFtX=Math.max(-400,Math.min(400, camFtX+dFtX));
    camFtY=Math.max(-400,Math.min(400,camFtY+dFtY));
    pLastPx=p.x; pLastPy=p.y;
    clampCam(); updateCoords(); drawAll();
  }
},{passive:false});
plan.addEventListener('touchend',()=>pDrag=false);

// ── Geometry helpers ──────────────────────────────────────────────────────
function getPlateWidth() {
  // Return plate width in inches based on current selection
  if (currentPlateSize === 'quarter') {
    return 4.25; // 4.25 inches wide for quarter plate landscape
  } else if (currentPlateSize === '5x7-landscape') {
    return 7.0; // 7 inches wide for 5x7 landscape
  } else if (currentPlateSize === '5x7-portrait') {
    return 5.0; // 5 inches wide for 5x7 portrait
  } else if (currentPlateSize === '8x10-landscape') {
    return 10.0; // 10 inches wide for 8x10 landscape
  } else if (currentPlateSize === '8x10-portrait') {
    return 8.0; // 8 inches wide for 8x10 portrait
  } else if (currentPlateSize === '2x2.5') {
    return 2.0; // 2 inches wide for 2x2.5 plate
  }
  return 2.0; // default to 2x2.5
}

function getPlateHeight() {
  // Return plate height in inches based on current selection
  if (currentPlateSize === 'quarter') {
    return 3.25; // 3.25 inches tall for quarter plate landscape
  } else if (currentPlateSize === '5x7-landscape') {
    return 5.0; // 5 inches tall for 5x7 landscape
  } else if (currentPlateSize === '5x7-portrait') {
    return 7.0; // 7 inches tall for 5x7 portrait
  } else if (currentPlateSize === '8x10-landscape') {
    return 8.0; // 8 inches tall for 8x10 landscape
  } else if (currentPlateSize === '8x10-portrait') {
    return 10.0; // 10 inches tall for 8x10 portrait
  } else if (currentPlateSize === '2x2.5') {
    return 2.5; // 2.5 inches tall for 2x2.5 plate
  }
  return 2.5; // default to 2x2.5
}

function getFovDeg(){
  // Check which mode is active with fallbacks for uninitialized DOM
  try {
    const fovModeEl = document.getElementById('fov-mode');
    const cameraModeEl = document.getElementById('camera-mode');
    
    if (!fovModeEl || !cameraModeEl) {
      return 15; // Default FOV during initialization
    }
    
    const isFovMode = fovModeEl.checked;
    const isCameraMode = cameraModeEl.checked;
    
    if (isCameraMode) {
      // Return FOV from camera type settings
      const cameraTypeEl = document.getElementById('camera-type');
      if (!cameraTypeEl) return 15;
      const cameraType = cameraTypeEl.value;
      return getCameraSettings(cameraType).fov;
    } else if (isFovMode) {
      // Return FOV directly from slider
      const fovSliderEl = document.getElementById('fov-slider');
      if (!fovSliderEl) return 15;
      return parseFloat(fovSliderEl.value);
    } else {
      // Calculate FOV from focal length using current plate width
      const focalEl = document.getElementById('focal');
      if (!focalEl) return 15;
      const focalLength=parseFloat(focalEl.value);
      const plateWidthInches = getPlateWidth();
      const fovRad = 2 * Math.atan(plateWidthInches / (2 * focalLength));
      return fovRad * 180 / Math.PI;
    }
  } catch (e) {
    return 15; // Fallback to 15 degrees on any error
  }
}

function getCameraSettings(cameraType) {
  // Use actual 2x2.5 inch plate dimensions for realistic FOV calculations
  const plateWidth = 2.0; // 2 inches wide
  const plateHeight = 2.5; // 2.5 inches tall
  
  const settings = {
    'engraving': { 
      focal: 8.5, 
      fov: 2 * Math.atan(plateWidth / (2 * 8.5)) * 180 / Math.PI, 
      vFov: 2 * Math.atan(plateWidth / (2 * 8.5)) * 180 / Math.PI * (plateHeight/plateWidth) 
    },
    'standard': { 
      focal: 12.2, 
      fov: 2 * Math.atan(plateWidth / (2 * 12.2)) * 180 / Math.PI, 
      vFov: 2 * Math.atan(plateWidth / (2 * 12.2)) * 180 / Math.PI * (plateHeight/plateWidth) 
    },
    'telephoto': { 
      focal: 24.0, 
      fov: 2 * Math.atan(plateWidth / (2 * 24.0)) * 180 / Math.PI, 
      vFov: 2 * Math.atan(plateWidth / (2 * 24.0)) * 180 / Math.PI * (plateHeight/plateWidth) 
    },
    'wide': { 
      focal: 6.9, 
      fov: 2 * Math.atan(plateWidth / (2 * 6.9)) * 180 / Math.PI, 
      vFov: 2 * Math.atan(plateWidth / (2 * 6.9)) * 180 / Math.PI * (plateHeight/plateWidth) 
    },
    'fisheye': { 
      focal: 4.0, 
      fov: 2 * Math.atan(plateWidth / (2 * 4.0)) * 180 / Math.PI, 
      vFov: 2 * Math.atan(plateWidth / (2 * 4.0)) * 180 / Math.PI * (plateHeight/plateWidth) 
    }
  };
  return settings[cameraType] || settings['standard'];
}
// Convert rotation degrees (-90 to +90) to canvas math angle (0=east, CCW positive)
// Rotation 0° = east, +90° = north, -90° = south
function getCamAngle(){ return camRotation * Math.PI / 180; }

function getConeParams(s, ox, oy){
  const cx=ox+camFtX*s, cy=oy-camFtY*s;
  
  // Camera cone parameters - no hard-coded building data
  const fovDeg=getFovDeg();
  const ca=getCamAngle(), fR=fovDeg*Math.PI/180, FAR=9000;
  const rv1={x:cx+Math.cos(ca-fR/2)*FAR, y:cy+Math.sin(ca-fR/2)*FAR};
  const rv2={x:cx+Math.cos(ca+fR/2)*FAR, y:cy+Math.sin(ca+fR/2)*FAR};
  
  return{cx,cy,ca,fR,FAR,rv1,rv2};
}

function extPt(cx,cy,ca,FAR,tx,ty){
  const dx=tx-cx,dy=ty-cy,d=Math.sqrt(dx*dx+dy*dy);
  if(d<0.001)return{x:cx+Math.cos(ca)*FAR,y:cy+Math.sin(ca)*FAR};
  return{x:cx+(dx/d)*FAR,y:cy+(dy/d)*FAR};
}

