// Function to export map data as JSON for GitHub version
window.exportMapDataForGitHub = function() {
  const mapPositions = {};
  
  for (let i = 0; i < 6; i++) {
    const storageKey = 'plateH_map' + i + '_settings';
    const savedSettings = localStorage.getItem(storageKey);
    
    if (savedSettings) {
      try {
        const parsed = JSON.parse(savedSettings);
        mapPositions[i] = {
          name: MAP_CONFIGS[i].name,
          filename: MAP_CONFIGS[i].filename,
          scale: parsed.scale,
          rotation: parsed.rotation,
          x: parsed.x,
          y: parsed.y,
          opacity: parsed.opacity
        };
      } catch (e) {
        console.log(`Map ${i} (${MAP_CONFIGS[i].name}): Failed to parse settings`);
      }
    }
  }
  
  // Create formatted JSON string
  const jsonExport = JSON.stringify(mapPositions, null, 2);
  
  console.log('=== MAP DATA FOR GITHUB VERSION ===');
  console.log('Copy this JSON data and paste into GitHub version:');
  console.log(jsonExport);
  console.log('==========================================');
  
  // Also create a downloadable file
  const blob = new Blob([jsonExport], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'map-positions-for-github.json';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  
  console.log('📁 Downloaded map-positions-for-github.json file');
  
  return mapPositions;
};

// Function to save specific map data from user input
window.saveMapDataFromInput = function(mapIndex, scale, rotation, x, y, opacity = 50) {
  const mapData = {
    scale: parseFloat(scale),
    rotation: parseFloat(rotation),
    x: parseFloat(x),
    y: parseFloat(y),
    opacity: parseFloat(opacity)
  };
  
  // Save to localStorage
  const storageKey = 'plateH_map' + mapIndex + '_settings';
  localStorage.setItem(storageKey, JSON.stringify(mapData));
  
  console.log(`Saved Map ${mapIndex} (${MAP_CONFIGS[mapIndex].name}) settings:`, mapData);
  
  return mapData;
};

