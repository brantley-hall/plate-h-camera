// ZZZ: west face x=0, north face y=0, extends east 100ft, south 180ft
// Row houses and church use same Y positions as plan (slider-adjustable at render time)
function getBuildings(){
  // Only use BIS data for ray-casting
  const buildings = [];
  
  // Add all buildings from BIS (Building Info System)
  const bisBuildings = BIS.getForRayCasting();
  console.log('Ray-casting BIS buildings:', bisBuildings);
  bisBuildings.forEach(building => {
    console.log(`Adding ${building.name} to ray-casting: x0=${building.x0}, x1=${building.x1}, y0=${building.y0}, y1=${building.y1}`);
    console.log(`Camera position: camFtX=${camFtX}, camFtY=${camFtY}, rotation=${camRotation}°`);
    
    // Use consistent coordinates without flipping
    buildings.push({
      x0: building.x0,
      x1: building.x1,
      y0: building.y0,  // Use original Y coordinate
      y1: building.y1,  // Use original Y coordinate
      h: building.h || building.height, // FIX: Fallback to .height to catch the true property name
      col: building.col,
      name: building.name
    });
    
    console.log(`Using consistent coordinates for ${building.name}: y0=${building.y0}, y1=${building.y1}`);
  });
  
  return buildings;
}

// ============================================================================
// 3D VOLUMETRIC CUBE INTERSECTION ENGINE (FLAT ROOFS & OVER-VIEWING)
// ============================================================================

/**
 * Helper function to modulate shade values for realistic 3D face definition
 */
function adjustColorBrightness(rgbaStr, factor) {
    if (!rgbaStr.includes('rgba')) return rgbaStr;
    let parts = rgbaStr.match(/[\d.]+/g);
    if (!parts || parts.length < 3) return rgbaStr;
    let r = Math.min(255, Math.max(0, parseInt(parts[0]) * factor));
    let g = Math.min(255, Math.max(0, parseInt(parts[1]) * factor));
    let b = Math.min(255, Math.max(0, parseInt(parts[2]) * factor));
    let a = parts[3] ? parts[3] : "1";
    return `rgba(${Math.round(r)},${Math.round(g)},${Math.round(b)},${a})`;
}

/**
 * Calculates the exact 3D intersection point of a camera ray with a solid building block.
 * Supports flat roofs, solid side faces, and ray-continuations ("see-over").
 * @param {Object} rayOrigin - {x: camX, y: camY, z: camZ}
 * @param {Object} rayDir - {x: dx, y: dy, z: dz} normalized direction vectors
 * @param {Object} b - Building definition with limits {x0, x1, y0, y1, height, col}
 * @return {Object|null} Intersection metrics or null if missed
 */
function intersectBuilding3DCube(rayOrigin, rayDir, b) {
    // 1. Calculate intervals for X and Y axes (AABB Intersection algorithm)
    let tXMin = (b.x0 - rayOrigin.x) / rayDir.x;
    let tXMax = (b.x1 - rayOrigin.x) / rayDir.x;
    if (tXMin > tXMax) { let temp = tXMin; tXMin = tXMax; tXMax = temp; }

    let tYMin = (b.y0 - rayOrigin.y) / rayDir.y;
    let tYMax = (b.y1 - rayOrigin.y) / rayDir.y;
    if (tYMin > tYMax) { let temp = tYMin; tYMin = tYMax; tYMax = temp; }

    // Check if the ray missed the 2D footprint entirely
    if ((tXMin > tYMax) || (tYMin > tXMax)) return null;

    // Entry and exit distances along the horizontal path
    let tEnter = Math.max(tXMin, tYMin);
    let tExit = Math.min(tXMax, tYMax);

    // If the building volume is behind the camera ray
    if (tExit < 0) return null;
    
    // Determine the distance to the point where ray meets the solid block
    let tHit = tEnter;
    if (tHit < 0) tHit = 0; // Camera inside the bounding box footprint

    // 2. Calculate the exact 3D entry point coordinates
    let hitX = rayOrigin.x + rayDir.x * tHit;
    let hitY = rayOrigin.y + rayDir.y * tHit;
    let hitZ = rayOrigin.z + rayDir.z * tHit;

    // 3. Evaluate Roof Cap vs Vertical Walls
    // Check for roof intersection from any angle
    if (rayDir.z !== 0) {
        let tRoof = (b.h - rayOrigin.z) / rayDir.z;
        // Verify if the roof intersection point lands within the horizontal boundary limits
        if (tRoof >= tEnter && tRoof <= tExit && tRoof > 0) {
            let roofHitX = rayOrigin.x + rayDir.x * tRoof;
            let roofHitY = rayOrigin.y + rayDir.y * tRoof;
            
            // Calculate distance relative to horizontal baseline projection
            let horizontalDist = Math.sqrt(Math.pow(roofHitX - rayOrigin.x, 2) + Math.pow(roofHitY - rayOrigin.y, 2));
            
            // Return designated surface metrics for the top flat roof
            return {
                distance: horizontalDist,
                hitZ: b.h,
                isRoof: true,
                color: adjustColorBrightness(b.col, 1.25) // Use 1.25x lighting multiplier for roofs
            };
        }
    }

    // 4. Ray hits a vertical wall surface of the cube structure
    if (tEnter >= 0) {
        let horizontalDist = Math.sqrt(Math.pow(hitX - rayOrigin.x, 2) + Math.pow(hitY - rayOrigin.y, 2));
        
        // Determine lighting shading variant depending on which wall face was intersected
        let faceShading = 1.0;
        if (Math.abs(hitX - b.x0) < 0.01 || Math.abs(hitX - b.x1) < 0.01) faceShading = 0.85; // E/W walls
        if (Math.abs(hitY - b.y0) < 0.01 || Math.abs(hitY - b.y1) < 0.01) faceShading = 0.70; // N/S walls

        return {
            distance: horizontalDist,
            hitZ: hitZ,
            isRoof: false,
            color: adjustColorBrightness(b.col, faceShading)
        };
    }

    return null;
}

function castRay3DSpace(rayOrigin, rayDir, buildings) {
    let closestHit = null;
    let minDistance = Infinity;

    buildings.forEach(building => {
        let hit = intersectBuilding3DCube(rayOrigin, rayDir, building);
        if (hit && hit.distance < minDistance) {
            // FIX: Track physical structure bounds using building.h
            if (hit.isRoof || (hit.hitZ >= 0 && hit.hitZ <= building.h)) {
                minDistance = hit.distance;
                closestHit = hit;
            }
        }
    });

    return closestHit;
}

// Simple 2D rayAABB for testing
function rayAABB(ox,oy,dx,dy,b){
  let tmin=-1e9, tmax=1e9;
  if(Math.abs(dx)>1e-10){
    const t1=(b.x0-ox)/dx, t2=(b.x1-ox)/dx;
    tmin=Math.max(tmin,Math.min(t1,t2)); tmax=Math.min(tmax,Math.max(t1,t2));
  } else if(ox<=b.x0||ox>=b.x1) return null;
  if(Math.abs(dy)>1e-10){
    const t1=(b.y0-oy)/dy, t2=(b.y1-oy)/dy;
    tmin=Math.max(tmin,Math.min(t1,t2)); tmax=Math.min(tmax,Math.max(t1,t2));
  } else if(oy<=b.y0||oy>=b.y1) return null;
  if(tmax<0.5||tmin>tmax) return null;
  const t=tmin>0.5?tmin:tmax;
  if(t<0.5) return null;
  return {t, col:b.col, name:b.name};
}

function updateRayCasting(){
  if(!plateStrip){
    plateStrip=document.getElementById('plateStrip');
    psctx=plateStrip.getContext('2d');
  }
  const PW=plateStrip.width, PH=plateStrip.height;
  const fovDeg=getFovDeg();
  const plateWidthInches = getPlateWidth();
  const plateHeightInches = getPlateHeight();
  const vFovDeg = fovDeg * (plateHeightInches/plateWidthInches); // aspect ratio
  const aimRad=-camRotation*Math.PI/180;
  const halfH=fovDeg/2*Math.PI/180;
  const halfV=vFovDeg/2*Math.PI/180;
  const CAM_H=cameraHeight;
  const CAMERA_TILT_UP=cameraTiltUp; // Use global camera tilt variable
  const aimDx=Math.cos(aimRad),aimDy=Math.sin(aimRad);
  const rightDx=Math.sin(aimRad),rightDy=-Math.cos(aimRad);
  const blds=getBuildings();
  const imgData=psctx.createImageData(PW,PH);
  const d=imgData.data;
  const SKY=[200,212,232],GND=[196,168,114];
  
    // Dynamic counts object - will be populated as buildings are encountered
  const counts={sky:0,ground:0};
  const midRow=Math.floor(PH/2);
  const horizAng=Math.atan2(-CAM_H,1000);

  // Color parser cache
  const _tmp=document.createElement('canvas');_tmp.width=_tmp.height=1;
  const _tx=_tmp.getContext('2d');
  const _cc={};
  function rgb(col){
    if(_cc[col])return _cc[col];
    _tx.clearRect(0,0,1,1);_tx.fillStyle=col;_tx.fillRect(0,0,1,1);
    const p=_tx.getImageData(0,0,1,1).data;
    return _cc[col]=[p[0],p[1],p[2]];
  }

  function bldH(b){
    if(b.h !== undefined) return b.h; // Use height from building object
    return 0; // Default height if not specified
  }

  // ============================================================================
// FIXED: UNIFIED 3D VOLUMETRIC VIEWPORT GENERATION ENGINE
// ============================================================================
  for (let py = 0; py < PH; py++) {
    // Vertical angle calculation matching standard screen coordinates deflection
    const vAng = ((1 - py / (PH - 1)) - 0.5) * 2 * halfV + CAMERA_TILT_UP;
    const slopeZ = Math.tan(vAng); // Upward or downward tangent component for the 3D ray

    for (let px = 0; px < PW; px++) {
      const hAng = ((1 - px / (PW - 1)) - 0.5) * 2 * halfH;
      const angle = aimRad + hAng;

      // Project explicit coordinates on the horizontal plane
      const dirX = Math.cos(angle);
      const dirY = Math.sin(angle);

      // Construct a clean, standardized 3D ray direction struct
      const normDir = { x: dirX, y: dirY, z: slopeZ };
      const rayOrigin = { x: camFtX, y: camFtY, z: CAM_H };

      // Query the unified 3D volumetric cube intersection solver
      const closestHit = castRay3DSpace(rayOrigin, normDir, blds);

      let r = SKY[0], g = SKY[1], b2 = SKY[2]; // Default environment setup: Sky background

      if (closestHit && closestHit.name !== 'sky') {
        // A physical structure surface was intersected by the ray
        const c = rgb(closestHit.color);
        r = Math.min(255, Math.round(c[0]));
        g = Math.min(255, Math.round(c[1]));
        b2 = Math.min(255, Math.round(c[2]));
        
        if (py === midRow) counts[closestHit.name] = (counts[closestHit.name] || 0) + 1;
      } else {
        // No building hit: evaluate background texture boundaries (Sky vs Ground)
        if (vAng > horizAng) {
          r = SKY[0]; g = SKY[1]; b2 = SKY[2];
          if (py === midRow) counts.sky++;
        } else {
          r = GND[0]; g = GND[1]; b2 = GND[2];
          if (py === midRow) counts.ground++;
        }
      }

      // Commit color outputs directly to the native active canvas data array
      const idx = (py * PW + px) * 4;
      d[idx] = r;
      d[idx + 1] = g;
      d[idx + 2] = b2;
      d[idx + 3] = 255;
    }
  }
  psctx.putImageData(imgData,0,0);

  // Draw occlusion zone if enabled
  if (occlusionZonePercent > 0) {
    const occlusionHeight = Math.floor(PH * (occlusionZonePercent / 100));
    const occlusionStartY = PH - occlusionHeight;
    
    // Draw fully opaque occlusion zone
    psctx.fillStyle = 'rgba(0, 0, 0, 1)';
    psctx.fillRect(0, occlusionStartY, PW, occlusionHeight);
    
    // Add subtle border line at occlusion boundary
    psctx.strokeStyle = 'rgba(255, 255, 255, 0.2)';
    psctx.lineWidth = 1;
    psctx.beginPath();
    psctx.moveTo(0, occlusionStartY);
    psctx.lineTo(PW, occlusionStartY);
    psctx.stroke();
  }

  // ZZZ NW corner stats - use BIS data
  let zzzNWplate=null;
  let zzzWorldN = 0; // Default to origin if BIS not available
  if (BIS && BIS.getBuilding) {
    const zzzBuilding = BIS.getBuilding('ZZZ');
    if (zzzBuilding) {
      zzzWorldN = zzzBuilding.nwCoordinate.y; // Get north coordinate from BIS
    }
  }
  const ddx=0-camFtX, ddy=zzzWorldN-camFtY;
  const mf=ddx*aimDx+ddy*aimDy;
  if(mf>0.5){
    const ml=ddx*rightDx+ddy*rightDy;
    zzzNWplate=Math.round((1-(Math.atan2(ml,mf)/(2*halfH)+0.5))*(PW-1));
  }

  const N=PW;
  const dist=Math.round(Math.sqrt(camFtX*camFtX+camFtY*camFtY));
  document.getElementById('ps-pos').textContent=`(${camFtX}, ${camFtY>=0?'+':''}${camFtY}) ft`;
  document.getElementById('ps-rot').textContent=`${camRotation}°`;
  document.getElementById('ps-fov').textContent=`${fovDeg}° / ${vFovDeg.toFixed(1)}°`;
  // Dynamic stats display - only show buildings that were actually encountered
  if(document.getElementById('ps-zzz')) document.getElementById('ps-zzz').textContent=`${Math.round((counts.ZZZ||0)/N*100)}%`;
  if(document.getElementById('ps-ch')) document.getElementById('ps-ch').textContent=`${Math.round(((counts.ChN||0)+(counts.ChM||0)+(counts.ChS||0))/N*100)}%`;
  if(document.getElementById('ps-rh1')) document.getElementById('ps-rh1').textContent=`${Math.round((counts.RH1||0)/N*100)}%`;
  if(document.getElementById('ps-rh2')) document.getElementById('ps-rh2').textContent=`${Math.round((counts.RH2||0)/N*100)}%`;
  if(document.getElementById('ps-sky')) document.getElementById('ps-sky').textContent=`${Math.round((counts.sky||0)/N*100)}%`;
  document.getElementById('ps-dist').textContent=`${dist} ft`;
  document.getElementById('ps-nwpos').textContent=zzzNWplate!==null
    ?`${Math.round(zzzNWplate/PW*100)}% from left`:'outside frame';
  document.getElementById('plate-caption').textContent='';
}


// ── Plate Size Management ──────────────────────────────────────────────────────

// Add event listeners for plate size radio buttons
document.addEventListener('DOMContentLoaded', function() {
  const plateSizeRadios = document.querySelectorAll('input[name="plate-size"]');
  plateSizeRadios.forEach(radio => {
    radio.addEventListener('change', function() {
      if (this.checked) {
        updatePlateSize(this.value);
      }
    });
  });
  
  // Initialize with default 2x2.5 size
  updatePlateSize('2x2.5');
});

</script>
<script>
// ── Temporary Map Controls ─────────────────────────────────────────────────────
// Additional map control variables
let showRoadways = true; // Default to visible
let showAlignmentGrid = true;

</script>
<script>
(function(){
  const opacitySlider = document.getElementById('overlayOpacity');
  const opacityLabel  = document.getElementById('overlayOpacityVal');
  const img    = document.getElementById('dagOverlay');
  
  // Opacity control
  opacitySlider.addEventListener('input', function(){
    const v = parseInt(this.value);
    img.style.opacity = v / 100;
    opacityLabel.textContent = v + '%';
  });
  
  // Initialize overlay opacity to default value
  const initialOpacity = parseInt(opacitySlider.value);
  img.style.opacity = initialOpacity / 100;
  opacityLabel.textContent = initialOpacity + '%';
  
  
  })();
// ── Solution Management System ─────────────────────────────────────────────────────
let solutionsData = null;

// Load solutions from JSON file
async function loadSolutionsData() {
  try {
    const response = await fetch('solutions.json');
    solutionsData = await response.json();
    console.log('Solutions loaded:', solutionsData);
  } catch (error) {
    console.error('Error loading solutions:', error);
    solutionsData = { solutions: {} };
  }
}

// Load a specific solution by name
function loadSolution(solutionName) {
  if (!solutionsData || !solutionsData.solutions[solutionName]) {
    console.error('Solution not found:', solutionName);
    alert('Solution "' + solutionName + '" not found!');
    return;
  }
  
  const solution = solutionsData.solutions[solutionName];
  console.log('Loading solution:', solution);
  
  // Apply camera settings
  if (solution.camera) {
    // Camera position
    if (solution.camera.position) {
      if (solution.camera.position.x !== undefined) {
        camFtX = solution.camera.position.x;
        const camXInput = document.getElementById('camX-input');
        if (camXInput) camXInput.value = solution.camera.position.x;
      }
      if (solution.camera.position.y !== undefined) {
        camFtY = solution.camera.position.y;
        const camYInput = document.getElementById('camY-input');
        if (camYInput) camYInput.value = solution.camera.position.y;
      }
      if (solution.camera.position.height !== undefined) {
        cameraHeight = solution.camera.position.height;
        const camHeightSlider = document.getElementById('cameraHeight');
        if (camHeightSlider) camHeightSlider.value = solution.camera.position.height;
        const camHeightOut = document.getElementById('cameraHeight-out');
        if (camHeightOut) camHeightOut.textContent = solution.camera.position.height.toFixed(1) + ' ft';
      }
    }
    
    // Camera rotation
    if (solution.camera.rotation !== undefined) {
      camRotation = solution.camera.rotation;
      const rotationSlider = document.getElementById('rotation');
      if (rotationSlider) rotationSlider.value = solution.camera.rotation;
      const rotationInput = document.getElementById('rotation-input');
      if (rotationInput) rotationInput.value = solution.camera.rotation;
      const rotOut = document.getElementById('rot-out');
      if (rotOut) rotOut.textContent = solution.camera.rotation + '°';
    }
    
    // Camera optics
    if (solution.camera.optics) {
      if (solution.camera.optics.horizontalFOV !== undefined) {
        const fovSlider = document.getElementById('fov-slider');
        if (fovSlider) fovSlider.value = solution.camera.optics.horizontalFOV;
        const fovSliderOut = document.getElementById('fov-slider-out');
        if (fovSliderOut) fovSliderOut.textContent = solution.camera.optics.horizontalFOV + ' degrees';
        const fovOut = document.getElementById('fov-out');
        if (fovOut) fovOut.textContent = solution.camera.optics.horizontalFOV + ' degrees';
      }
      
      // Calculate and set vertical FOV
      if (solution.camera.optics.verticalFOV !== undefined) {
        const vFovOut = document.getElementById('vfov-out');
        if (vFovOut) vFovOut.textContent = solution.camera.optics.verticalFOV + ' degrees';
      }
    }
  }
  
  // Apply building settings
  if (solution.buildings) {
    // NYU Building
    if (solution.buildings.NYU) {
      if (solution.buildings.NYU.position !== undefined) {
        const nyuSlider = document.getElementById('nyuslide');
        if (nyuSlider) nyuSlider.value = solution.buildings.NYU.position;
        const nyuOut = document.getElementById('nyu-out');
        if (nyuOut) nyuOut.textContent = solution.buildings.NYU.position;
      }
      if (solution.buildings.NYU.height !== undefined) {
        const nyuHeightSlider = document.getElementById('nyuheight');
        if (nyuHeightSlider) nyuHeightSlider.value = solution.buildings.NYU.height;
        const nyuHeightOut = document.getElementById('nyuheight-out');
        if (nyuHeightOut) nyuHeightOut.textContent = solution.buildings.NYU.height;
      }
    }
    
    // Row Houses
    if (solution.buildings.RowHouses) {
      if (solution.buildings.RowHouses.RH1) {
        if (solution.buildings.RowHouses.RH1.position !== undefined) {
          const rh1Slider = document.getElementById('rh1slide');
          if (rh1Slider) rh1Slider.value = solution.buildings.RowHouses.RH1.position;
          const rh1Out = document.getElementById('rh1-out');
          if (rh1Out) rh1Out.textContent = solution.buildings.RowHouses.RH1.position;
        }
        if (solution.buildings.RowHouses.RH1.height !== undefined) {
          const rh1HeightSlider = document.getElementById('rh1height');
          if (rh1HeightSlider) rh1HeightSlider.value = solution.buildings.RowHouses.RH1.height;
          const rh1HeightOut = document.getElementById('rh1height-out');
          if (rh1HeightOut) rh1HeightOut.textContent = solution.buildings.RowHouses.RH1.height;
        }
      }
      
      if (solution.buildings.RowHouses.RH2) {
        if (solution.buildings.RowHouses.RH2.position !== undefined) {
          const rh2Slider = document.getElementById('rh2slide');
          if (rh2Slider) rh2Slider.value = solution.buildings.RowHouses.RH2.position;
          const rh2Out = document.getElementById('rh2-out');
          if (rh2Out) rh2Out.textContent = solution.buildings.RowHouses.RH2.position;
        }
        if (solution.buildings.RowHouses.RH2.height !== undefined) {
          const rh2HeightSlider = document.getElementById('rh2height');
          if (rh2HeightSlider) rh2HeightSlider.value = solution.buildings.RowHouses.RH2.height;
          const rh2HeightOut = document.getElementById('rh2height-out');
          if (rh2HeightOut) rh2HeightOut.textContent = solution.buildings.RowHouses.RH2.height;
        }
      }
    }
    
    // Church
    if (solution.buildings.Church) {
      if (solution.buildings.Church.distance !== undefined) {
        const churchDistSlider = document.getElementById('churchdist');
        if (churchDistSlider) churchDistSlider.value = solution.buildings.Church.distance;
        const churchDistOut = document.getElementById('churchdist-out');
        if (churchDistOut) churchDistOut.textContent = solution.buildings.Church.distance;
      }
      if (solution.buildings.Church.position !== undefined) {
        const churchSlider = document.getElementById('churchslide');
        if (churchSlider) churchSlider.value = solution.buildings.Church.position;
        const churchOut = document.getElementById('church-out');
        if (churchOut) churchOut.textContent = solution.buildings.Church.position;
      }
      if (solution.buildings.Church.heights) {
        if (solution.buildings.Church.heights.north !== undefined) {
          const chnHeightSlider = document.getElementById('chnheight');
          if (chnHeightSlider) chnHeightSlider.value = solution.buildings.Church.heights.north;
          const chnHeightOut = document.getElementById('chnheight-out');
          if (chnHeightOut) chnHeightOut.textContent = solution.buildings.Church.heights.north;
        }
        if (solution.buildings.Church.heights.center !== undefined) {
          const chmHeightSlider = document.getElementById('chmheight');
          if (chmHeightSlider) chmHeightSlider.value = solution.buildings.Church.heights.center;
          const chmHeightOut = document.getElementById('chmheight-out');
          if (chmHeightOut) chmHeightOut.textContent = solution.buildings.Church.heights.center;
        }
        if (solution.buildings.Church.heights.south !== undefined) {
          const chsHeightSlider = document.getElementById('chsheight');
          if (chsHeightSlider) chsHeightSlider.value = solution.buildings.Church.heights.south;
          const chsHeightOut = document.getElementById('chsheight-out');
          if (chsHeightOut) chsHeightOut.textContent = solution.buildings.Church.heights.south;
        }
      }
    }
  }
  
  // Update display
  updateCoords();
  drawAll();
  
  alert('Solution "' + solutionName + '" loaded successfully!');
}

// Save current configuration as a solution
function saveCurrentSolution() {
  const solutionName = prompt('Enter a name for this solution:');
  if (!solutionName) return;
  
  const currentSolution = {
    name: solutionName,
    description: prompt('Enter a description (optional):') || '',
    camera: {
      position: {
        x: camFtX,
        y: camFtY,
        height: cameraHeight
      },
      rotation: camRotation,
      optics: {
        mode: document.getElementById('fov-mode').checked ? 'FOV' : 'Camera Type',
        horizontalFOV: getFovDeg(),
        verticalFOV: getFovDeg() * (getPlateHeight() / getPlateWidth())
      }
    },
    buildings: {
      NYU: {
        position: parseInt(document.getElementById('nyuslide').value),
        height: parseInt(document.getElementById('nyuheight').value)
      },
      RowHouses: {
        RH1: {
          position: parseInt(document.getElementById('rh1slide').value),
          height: parseInt(document.getElementById('rh1height').value)
        },
        RH2: {
          position: parseInt(document.getElementById('rh2slide').value),
          height: parseInt(document.getElementById('rh2height').value)
        }
      },
      Church: {
        distance: parseInt(document.getElementById('churchdist').value),
        position: parseInt(document.getElementById('churchslide').value),
        heights: {
          north: parseInt(document.getElementById('chnheight').value),
          center: parseInt(document.getElementById('chmheight').value),
          south: parseInt(document.getElementById('chsheight').value)
        }
      }
    }
  };
  
  // Save to localStorage (in a real implementation, this would save to the JSON file)
  const savedSolutions = JSON.parse(localStorage.getItem('customSolutions') || '{}');
  savedSolutions[solutionName] = currentSolution;
  localStorage.setItem('customSolutions', JSON.stringify(savedSolutions));
  
  alert('Solution "' + solutionName + '" saved to browser storage!');
}

// List all available solutions
function listSolutions() {
  let message = 'Available Solutions:\n\n';
  
  // Built-in solutions
  if (solutionsData && solutionsData.solutions) {
    message += 'Built-in Solutions:\n';
    for (const [name, solution] of Object.entries(solutionsData.solutions)) {
      message += `- ${name}: ${solution.description || 'No description'}\n`;
    }
    message += '\n';
  }
  
  // Custom solutions from localStorage
  const customSolutions = JSON.parse(localStorage.getItem('customSolutions') || '{}');
  if (Object.keys(customSolutions).length > 0) {
    message += 'Custom Solutions:\n';
    for (const [name, solution] of Object.entries(customSolutions)) {
      message += `- ${name}: ${solution.description || 'No description'}\n`;
    }
  } else {
    message += 'No custom solutions saved yet.\n';
  }
  
  alert(message);
}

// Initialize solutions on page load
document.addEventListener('DOMContentLoaded', function() {
  loadSolutionsData();
});

</script>
</body>
</html>
