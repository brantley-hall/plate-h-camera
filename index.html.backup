                   style="width:45px;font-size:0.5rem;font-family:'Source Code Pro',monospace;border:1px solid var(--rule);background:var(--paper);color:var(--ink);padding:1px;"
                   onchange="updateChurchSectionHeight('ChM', this.value)"> ft
          </div>
          <div><span style="color:var(--muted);">S Height:</span> 
            <input type="number" id="chs-height-${building.name}" value="${building.sections ? building.sections.find(s => s.name === 'ChS')?.height || 50 : 50}" 
                   style="width:45px;font-size:0.5rem;font-family:'Source Code Pro',monospace;border:1px solid var(--rule);background:var(--paper);color:var(--ink);padding:1px;"
                   onchange="updateChurchSectionHeight('ChS', this.value)"> ft
          </div>
        ` : `
          <div><span style="color:var(--muted);">Height:</span> 
            <input type="number" id="height-${building.name}" value="${building.height}" 
                   style="width:45px;font-size:0.5rem;font-family:'Source Code Pro',monospace;border:1px solid var(--rule);background:var(--paper);color:var(--ink);padding:1px;"
                   onchange="updateBuildingHeight('${building.name}', this.value)"> ft
          </div>
        `}
          <div><span style="color:var(--muted);">Color:</span> <span style="display:inline-block;width:12px;height:12px;background:${building.color};border:1px solid var(--rule);vertical-align:middle;margin-right:4px;"></span>${building.color}</div>
          <div><span style="color:var(--muted);">Source:</span> user</div>
        </div>
        `}
      </div>`;
    
    if (building.sections) {
      html += `<div style="font-size:0.55rem;margin-top:0.2rem;">
        <span style="color:var(--muted);">Sections:</span> ${building.sections.length}
      </div>`;
    }
    
    html += '</div>';
  });
  
  html += `<div style="font-size:0.55rem;color:var(--sepia);margin-top:0.5rem;text-align:center;">
    📊 Total: ${allBuildings.length} buildings
  </div>`;
  
  return html;
}

