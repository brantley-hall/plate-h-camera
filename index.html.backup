// BIS Display Functions for UI
function toggleBISDisplay() {
  const display = document.getElementById('bis-display');
  const button = document.getElementById('bis-display-toggle');
  const content = document.getElementById('bis-content');
  
  if (display.style.display === 'none') {
    // Show BIS display
    display.style.display = 'block';
    button.textContent = 'Exit Buildings';
    button.style.background = 'var(--rust)';
    button.style.color = 'var(--paper)';
    
    // Generate BIS content with retry mechanism
    content.innerHTML = generateBISContent();
    
    // If BIS not ready, retry after a short delay
    if (content.innerHTML.includes('not initialized') || content.innerHTML.includes('No buildings found')) {
      setTimeout(() => {
        content.innerHTML = generateBISContent();
      }, 500);
    }
  } else {
    // Hide BIS display
    display.style.display = 'none';
    button.textContent = 'BUILDINGS';
    button.style.background = 'var(--paper)';
    button.style.color = 'var(--ink)';
  }
}

