<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>NYU from Washington Square Park - Forensic Image Analysis</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Source+Code+Pro:wght@400;600&family=Spectral:ital,wght@0,300;0,400;1,300&display=swap');
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{--ink:#1a1208;--paper:#f4ede0;--aged:#e8d9c0;--aged-dark:#d4c4a8;--sepia:#8b6914;--rust:#c0392b;--muted:#6b5a3e;--rule:rgba(139,105,20,0.25);}
body{background:var(--paper);color:var(--ink);font-family:'Spectral',Georgia,serif;font-size:14px;line-height:1.5;min-height:100vh;}
.wrapper{max-width:1600px;margin:0 auto;padding:0.1rem 0.8rem 0.4rem;}

header{border-top:3px double var(--sepia);border-bottom:1px solid var(--rule);padding:0.1rem 0;margin-bottom:0.2rem;text-align:center;}
.eyebrow{font-family:'Source Code Pro',monospace;font-size:0.58rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--sepia);}
h1{font-family:'Playfair Display',Georgia,serif;font-size:clamp(1.1rem,2vw,1.5rem);font-weight:600;color:var(--ink);}
h1 em{font-style:italic;font-weight:400;color:var(--sepia);}

/* ── Two-column workspace (plan + plate) ── */
.workspace{display:grid;grid-template-columns:1fr 400px;gap:0.72rem;align-items:start;margin-bottom:0.1rem;}
/* ── RIGHT: Plate view ── */
.plate-col{display:flex;flex-direction:column;gap:0.1rem;justify-content:flex-end;max-height:calc(100vh - 250px);}

/* ── Slider panel (full width below workspace) ── */
.slider-panel{background:var(--aged);border:1px solid var(--rule);border-radius:4px;padding:0.4rem 1rem;margin-bottom:0.1rem;}
.slider-panel-inner{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:0.6rem 1.5rem;}
.col-1{grid-column:1;}
.col-2{grid-column:2;}
.col-3{grid-column:3;}
.col-4{grid-column:4;}

/* ── Slider sections ── */
.slider-group{}
.ctrl-section{margin-bottom:0.3rem;padding-bottom:0.3rem;border-bottom:1px solid var(--rule);}
.ctrl-section:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
.ctrl-section-title{font-family:'Source Code Pro',monospace;font-size:0.57rem;letter-spacing:0.13em;text-transform:uppercase;color:var(--sepia);font-weight:700;margin-bottom:0.2rem;}
.sl{display:flex;align-items:center;gap:5px;margin-bottom:1px;max-width:75%;}
.sl label{font-family:'Source Code Pro',monospace;font-size:0.6rem;color:var(--muted);flex:0 0 100px;line-height:1.2;}
.sl input[type=range]{flex:1;height:3px;-webkit-appearance:none;appearance:none;background:var(--sepia);border-radius:2px;outline:none;cursor:pointer;}
.sl input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:10px;height:10px;border-radius:50%;background:var(--ink);cursor:pointer;border:2px solid var(--paper);box-shadow:0 0 0 1px var(--sepia);}
.sl .v{font-family:'Source Code Pro',monospace;font-size:0.6rem;font-weight:700;color:var(--ink);min-width:32px;text-align:right;}
.sl-check{display:flex;align-items:center;gap:6px;font-family:'Source Code Pro',monospace;font-size:0.6rem;color:var(--muted);margin-top:2px;}
.coord-display{font-family:'Source Code Pro',monospace;font-size:0.62rem;color:var(--muted);text-align:center;padding:1px 0;margin-bottom:2px;}
.coord-display span{color:var(--rust);font-weight:700;}

/* ── CENTRE: Plan view ── */
.plan-col{display:flex;flex-direction:column;gap:0.2rem;}
.plan-wrap{border:1px solid var(--sepia);border-radius:2px;overflow:hidden;box-shadow:3px 3px 0 rgba(139,105,20,0.1);}
canvas#plan{display:block;width:100%;}
.legend{display:flex;flex-wrap:wrap;gap:0.25rem 0.7rem;padding:0.35rem 0.6rem;background:var(--aged);border:1px solid var(--rule);border-radius:3px;}
.leg{display:flex;align-items:center;gap:0.25rem;font-family:'Source Code Pro',monospace;font-size:0.57rem;color:var(--muted);}
.sw{width:9px;height:9px;border-radius:1px;flex-shrink:0;}

/* ── RIGHT: Plate view ── */
/* plate-col defined in workspace block above */
.plate-col-title{font-family:'Source Code Pro',monospace;font-size:0.57rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--sepia);text-align:center;}
.plate-border{border:3px solid var(--sepia);padding:3px;background:var(--ink);display:block;line-height:0;box-shadow:4px 4px 0 rgba(139,105,20,0.12);align-self:center;}
canvas#plateStrip{display:block;}
.plate-caption{font-family:'Source Code Pro',monospace;font-size:0.57rem;color:var(--muted);text-align:center;}
.plate-legend{display:flex;flex-wrap:wrap;gap:0.2rem 0.6rem;}
.plate-leg{display:flex;align-items:center;gap:0.25rem;font-family:'Source Code Pro',monospace;font-size:0.57rem;color:var(--muted);}
.plate-swatch{width:9px;height:9px;border-radius:1px;flex-shrink:0;}

/* Stats */
.stats{display:grid;grid-template-columns:1fr 1fr;gap:2px;}
.stat{background:var(--aged);border:1px solid var(--rule);border-radius:2px;padding:3px 6px;}
.stat-label{font-family:'Source Code Pro',monospace;font-size:0.52rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--muted);}
.stat-val{font-family:'Source Code Pro',monospace;font-size:0.68rem;font-weight:700;color:var(--ink);}

/* ── Instructions (bottom) ── */
.instructions{margin-top:0.4rem;border-top:2px solid var(--rule);padding-top:0.3rem;}
.instr-title{font-family:'Playfair Display',Georgia,serif;font-size:1rem;font-weight:600;color:var(--ink);margin-bottom:0.3rem;}
.instr-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:0.3rem;}
.instr-card{background:var(--aged);border:1px solid var(--rule);border-radius:3px;padding:0.3rem 0.5rem;}
.instr-head{font-family:'Source Code Pro',monospace;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--sepia);font-weight:700;margin-bottom:0.25rem;}
.instr-body{font-size:0.75rem;color:var(--muted);line-height:1.45;}
.instr-btn{width:100%;background:var(--paper);border:none;border-radius:3px;padding:0.6rem 0.8rem;cursor:pointer;text-align:left;font-family:inherit;transition:background 0.2s;}
.instr-btn:hover{background:var(--ink);color:var(--paper);}
.instr-btn:hover .instr-head{color:var(--aged);}
.instr-btn:hover .instr-body{color:var(--aged);}

footer{border-top:1px solid var(--rule);margin-top:1rem;padding-top:0.6rem;font-size:0.65rem;color:var(--muted);font-style:italic;text-align:center;}
footer strong{font-style:normal;color:var(--sepia);}

</style>
</head>
<body>
<div class="wrapper">

<header>
        <h1>NYU from Washington Square Park - <em>Forensic Image Analysis</em></h1>
</header>


<div class="workspace">

  <!-- CENTRE: PLAN VIEW -->
  <div class="plan-col">
    <div class="ctrl-section-title" style="margin-bottom:0.3rem;font-size:0.7rem;text-align:center;">Site Plan <span id="site-plan-map-name" style="font-family:'Georgia',serif;font-size:0.6rem;color:var(--rust);font-style:italic;">1852 Harrison</span></div>
    
        
          
            
          
    <div class="plan-wrap">
      <canvas id="plan"></canvas>
    </div>
    <div class="legend">
      <div class="leg"><div class="sw" style="background:rgba(255,0,0,0.7);border:1px dashed rgba(255,0,0,0.9)"></div>Red Shadow (Blind)</div>
      <div class="leg"><div class="sw" style="background:rgba(0,210,255,0.45);border:1px dashed rgba(0,210,255,0.9)"></div>Blue Shadow (Visible)</div>
            <div class="leg"><div class="sw" style="background:#c8d4e8;border:1px solid #8899aa"></div>Sky</div>
      <div class="leg"><div class="sw" style="background:#c4a872;border:1px solid #8b6914"></div>Ground</div>
      <div class="leg"><div class="sw" style="background:rgba(0,128,0,0.5);border:1px solid #006400"></div>Church N</div>
      <div class="leg"><div class="sw" style="background:rgba(255,255,0,0.5);border:1px solid #cccc00"></div>Church M</div>
      <div class="leg"><div class="sw" style="background:rgba(0,0,255,0.5);border:1px solid #0000cc"></div>Church S</div>
      <div class="leg"><div class="sw" style="background:rgba(189,186,181,0.6);border:1px solid #8b8680"></div>NYU</div>
      <div class="leg"><div class="sw" style="background:rgba(128,0,0,0.4);border:1px solid #800000"></div>RH1</div>
      <div class="leg"><div class="sw" style="background:rgba(139,90,43,0.5);border:1px solid #8b5a2b"></div>RH2</div>
    </div>
    
    <!-- Combined Interface Section -->
    <div style="margin-top:0.5rem;padding:0.5rem;background:var(--aged);border:1px solid var(--rule);border-radius:3px;">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
        <!-- User Interface Section -->
        <div style="display:flex;align-items:center;gap:0.5rem;">
          <div style="font-family:'Source Code Pro',monospace;font-size:0.7rem;color:var(--ink);white-space:nowrap;">User Interface</div>
          <div style="display:flex;align-items:center;gap:0.5rem;">
            <button id="site-scene-toggle" onclick="toggleSiteScene()" 
              style="font-family:'Source Code Pro',monospace;font-size:0.7rem;background:var(--paper);color:var(--ink);border:1px solid var(--sepia);border-radius:3px;padding:0.4rem 0.8rem;cursor:pointer;transition:all 0.2s;">
              SITE SCENE
            </button>
            <button id="tape-measure-toggle" onclick="toggleTapeMeasureMode()" 
              style="font-family:'Source Code Pro',monospace;font-size:0.7rem;background:var(--paper);color:var(--ink);border:1px solid var(--sepia);border-radius:3px;padding:0.4rem 0.8rem;cursor:pointer;transition:all 0.2s;">
              TAPE MEASURE
            </button>
            <button id="overlay-selector-toggle" onclick="toggleOverlaySelector()" 
              style="font-family:'Source Code Pro',monospace;font-size:0.7rem;background:var(--paper);color:var(--ink);border:1px solid var(--sepia);border-radius:3px;padding:0.4rem 0.8rem;cursor:pointer;transition:all 0.2s;">
              OVERLAY
            </button>
            <button id="help-toggle" onclick="toggleHelp()" 
              style="font-family:'Source Code Pro',monospace;font-size:0.7rem;background:var(--paper);color:var(--ink);border:1px solid var(--sepia);border-radius:3px;padding:0.4rem 0.8rem;cursor:pointer;transition:all 0.2s;">
              HELP
            </button>
            <div style="display:flex;align-items:center;gap:0.5rem;margin-left:1rem;">
              <label style="font-family:'Source Code Pro',monospace;font-size:0.6rem;color:var(--muted);">Show Map</label>
              <input type="checkbox" id="tempMapVisible" checked onchange="updateMapPosition()">
              <label style="font-family:'Source Code Pro',monospace;font-size:0.6rem;color:var(--muted);margin-left:1rem;">Show Roads</label>
              <input type="checkbox" id="showRoadways" checked onchange="updateMapPosition()">
            </div>
          </div>
        </div>
        
        <!-- Developer Interface Section -->
        <div style="display:flex;align-items:center;gap:0.5rem;">
          <div style="font-family:'Source Code Pro',monospace;font-size:0.7rem;color:var(--ink);white-space:nowrap;">Developer Interface</div>
          <button id="map-controls-toggle" onclick="toggleMapControls()" 
            style="font-family:'Source Code Pro',monospace;font-size:0.7rem;background:var(--paper);color:var(--ink);border:1px solid var(--sepia);border-radius:3px;padding:0.4rem 0.8rem;cursor:pointer;transition:all 0.2s;">
            MAP
          </button>
          <button id="bis-display-toggle" onclick="toggleBISDisplay()" 
            style="font-family:'Source Code Pro',monospace;font-size:0.7rem;background:var(--paper);color:var(--ink);border:1px solid var(--sepia);border-radius:3px;padding:0.4rem 0.8rem;cursor:pointer;transition:all 0.2s;">
            BUILDINGS
          </button>
        </div>
      </div>
    </div>
    
    <!-- Popup Displays Section -->
    <!-- Tape Measure Display -->
    <div id="tape-measure-display" style="display:none;background:var(--aged-dark);border:1px solid var(--rule);border-radius:3px;padding:0.3rem 0.5rem;margin-top:0.3rem;">
      <div style="font-family:'Source Code Pro',monospace;font-size:0.6rem;color:var(--muted);">
        Click and drag to measure
      </div>
    </div>
    
    <!-- BIS Display -->
    <div id="bis-display" style="display:none;background:var(--aged-dark);border:1px solid var(--rule);border-radius:3px;padding:0.3rem 0.5rem;margin-top:0.3rem;max-height:300px;overflow-y:auto;">
      <div id="bis-content" style="font-family:'Source Code Pro',monospace;font-size:0.6rem;color:var(--muted);">
        Loading building information...
      </div>
    </div>
    
    <!-- Help Display -->
    <div id="help-display" style="display:none;background:var(--aged-dark);border:1px solid var(--rule);border-radius:3px;padding:0.3rem 0.5rem;margin-top:0.3rem;max-height:400px;overflow-y:auto;">
      <div class="instr-title" style="font-size:0.8rem;margin-bottom:0.3rem;">Instructions — click any card to hear it read aloud</div>
      <div class="instr-grid" style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:0.3rem;">
        <div class="instr-card"><button class="instr-btn" onclick="speakInstruction('camera-position')"><div class="instr-head">Camera position</div><div class="instr-body">Control camera with X/Y sliders for east-west and north-south movement, plus height adjustment. Use exact inputs for precision. Camera moves freely - negative X is west, positive Y is north. Height sets eye level from 3-35 feet.</div></button></div>
        <div class="instr-card"><button class="instr-btn" onclick="speakInstruction('camera-rotation')"><div class="instr-head">Rotation</div><div class="instr-body">0° aims east toward NYU. Positive rotates north, negative south. Controls camera direction.</div></button></div>
        <div class="instr-card"><button class="instr-btn" onclick="speakInstruction('field-of-view')"><div class="instr-head">Field of view</div><div class="instr-body">FOV calculated from focal length. At <span id="instr-focal">8"</span> focal length, horizontal FOV is <span id="instr-hfov">14°</span> and vertical is <span id="instr-vfov">16.8°</span> for <span id="instr-plate-size">5×7</span> inch plate. Adjust focal length to change perspective.</div></button></div>
        <div class="instr-card"><button class="instr-btn" onclick="speakInstruction('image-overlay')"><div class="instr-head">Plate H overlay</div><div class="instr-body">Load the 1839 daguerreotype Plate H from McManus Collection to overlay on the simulated view. Adjust opacity slider (0-100%) to blend the historical photograph with the simulation for comparison.</div></button></div>
        <div class="instr-card"><button class="instr-btn" onclick="speakInstruction('building-movement')"><div class="instr-head">Building positions</div><div class="instr-body">Shift buildings north or south. Changes appear instantly in plan and ray-casting views. Test historical placement hypotheses.</div></button></div>
        <div class="instr-card"><button class="instr-btn" onclick="speakInstruction('historical-map')"><div class="instr-head">Historical map</div><div class="instr-body">The 1852 Harrison map underlies the plan at georeferenced scale. Origin (0,0) is the NYU NW corner. The Church of the Messiah is <span id="instruction-distance">777</span> ft to the east - matching current NYC online system measurements.</div></button></div>
        <div class="instr-card"><button class="instr-btn" onclick="speakInstruction('map-controls')"><div class="instr-head">Map controls</div><div class="instr-body">Toggle map positioning controls to scale, rotate, and offset the 1852 Harrison map. Save and load map positions for consistent reference. Adjust opacity and visibility for overlay comparison.</div></button></div>
        <div class="instr-card"><button class="instr-btn" onclick="speakInstruction('tape-measure')"><div class="instr-head">Tape measure</div><div class="instr-body">Click and drag to measure distances between any two points on the plan. Distance displays in feet with transparent blue label. Use for precise spatial analysis and measurements.</div></button></div>
        <div class="instr-card"><button class="instr-btn" onclick="speakInstruction('building-info')"><div class="instr-head">Building info</div><div class="instr-body">Toggle building information display to view detailed data about NYU, Row Houses, and Church buildings. Shows coordinates, dimensions, and properties for historical analysis.</div></button></div>
      </div>
    </div>
    
    <!-- Map Controls Display -->
    <div id="map-controls" style="display:none;background:var(--aged-dark);border:1px solid var(--rule);border-radius:3px;padding:0.3rem 0.5rem;margin-top:0.3rem;">
      <div style="font-family:'Source Code Pro',monospace;font-size:0.6rem;color:var(--muted);margin-bottom:0.2rem;">Map Positioning & Scaling</div>
      
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.3rem;">
        <div class="sl">
          <label>Scale</label>
          <input type="range" id="mapScale" min="0.1" max="3" step="0.01" value="0.41" oninput="updateMapPosition()">
          <input type="number" id="mapScale-input" min="0.1" max="3" step="0.01" value="0.41" style="width:60px;font-size:0.6rem;margin-left:0.2rem;" oninput="updateMapFromInput()">
          <span class="v" id="mapScale-out">0.41</span>
        </div>
        <div class="sl">
          <label>Rotation</label>
          <input type="range" id="mapRotation" min="-180" max="180" step="0.1" value="-20.5" oninput="updateMapPosition()">
          <input type="number" id="mapRotation-input" min="-180" max="180" step="0.1" value="-20.5" style="width:60px;font-size:0.6rem;margin-left:0.2rem;" oninput="updateMapFromInput()">
          <span class="v" id="mapRotation-out">-20.5°</span>
        </div>
        <div class="sl">
          <label>X Offset</label>
          <input type="range" id="mapOffsetX" min="-3000" max="3000" step="1" value="-1587" oninput="updateMapPosition()">
          <input type="number" id="mapOffsetX-input" min="-3000" max="3000" step="1" value="-1587" style="width:60px;font-size:0.6rem;margin-left:0.2rem;" oninput="updateMapFromInput()">
          <span class="v" id="mapOffsetX-out">-1587</span>
        </div>
        <div class="sl">
          <label>Y Offset</label>
          <input type="range" id="mapOffsetY" min="-3000" max="5000" step="1" value="3500" oninput="updateMapPosition()">
          <input type="number" id="mapOffsetY-input" min="-3000" max="5000" step="1" value="3500" style="width:60px;font-size:0.6rem;margin-left:0.2rem;" oninput="updateMapFromInput()">
          <span class="v" id="mapOffsetY-out">3500</span>
        </div>
      </div>
      
      <div style="display:flex;align-items:center;gap:0.5rem;margin-top:0.2rem;">
        <label style="font-family:'Source Code Pro',monospace;font-size:0.6rem;color:var(--muted);">Map</label>
        <select id="map-selector" onchange="switchMap(this.value)"
          style="font-family:'Source Code Pro',monospace;font-size:0.6rem;background:var(--aged);color:var(--ink);border:1px solid var(--sepia);border-radius:3px;padding:0.2rem;width:250px;min-width:250px;">
          <option value="0">Site Plan 1852 Harrison</option>
          <option value="1">1854 Perris</option>
          <option value="2">2026 NYC Zoning</option>
          <option value="3">1879 Brumley Map</option>
          <option value="4">1891 NYU Bromley</option>
          <option value="5">1893 Pincus Map</option>
        </select>
        <span id="current-map-name" style="font-family:'Source Code Pro',monospace;font-size:0.5rem;color:var(--sepia);margin-left:0.5rem;">Site Plan 1852 Harrison</span>
      </div>
      
            
      <div style="display:flex;align-items:center;gap:0.5rem;margin-top:0.2rem;">
        <label style="font-family:'Source Code Pro',monospace;font-size:0.6rem;color:var(--muted);">Opacity</label>
        <input type="range" id="mapOpacity" min="0" max="100" value="50" oninput="updateMapPosition()"
          style="width:120px;accent-color:var(--sepia);">
        <span style="font-family:'Source Code Pro',monospace;font-size:0.6rem;color:var(--sepia);min-width:28px;text-align:right;" id="mapOpacity-out">50%</span>
      </div>
      
          </div>
    
    <!-- Site Scene Selector Display -->
    <div id="site-scene-selector-display" style="display:none;background:var(--aged-dark);border:1px solid var(--rule);border-radius:3px;padding:0.3rem 0.5rem;margin-top:0.3rem;">
      <div style="font-family:'Source Code Pro',monospace;font-size:0.6rem;color:var(--muted);margin-bottom:0.2rem;">Select Site Scene Map</div>
      
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.5rem;">
        <!-- 1852 Harrison Thumbnail -->
        <div onclick="selectSiteScene(0)" style="cursor:pointer;border:1px solid var(--sepia);border-radius:3px;padding:0.3rem;background:var(--paper);transition:all 0.2s;" onmouseover="this.style.background='var(--sepia)'" onmouseout="this.style.background='var(--paper)'">
          <div style="width:100%;height:120px;background-image:url('1852MapNew YorkHarrison');background-size:cover;background-position:center;border-radius:2px;margin-bottom:0.3rem;"></div>
          <div style="font-family:'Source Code Pro',monospace;font-size:0.5rem;color:var(--ink);text-align:center;">1852 Harrison</div>
        </div>
        
        <!-- 1854 Perris Thumbnail -->
        <div onclick="selectSiteScene(1)" style="cursor:pointer;border:1px solid var(--sepia);border-radius:3px;padding:0.3rem;background:var(--paper);transition:all 0.2s;" onmouseover="this.style.background='var(--sepia)'" onmouseout="this.style.background='var(--paper)'">
          <div style="width:100%;height:120px;background-image:url('1854 Perris Map Extract');background-size:cover;background-position:center;border-radius:2px;margin-bottom:0.3rem;"></div>
          <div style="font-family:'Source Code Pro',monospace;font-size:0.5rem;color:var(--ink);text-align:center;">1854 Perris</div>
        </div>
        
        <!-- 2026 NYC Zoning Thumbnail -->
        <div onclick="selectSiteScene(2)" style="cursor:pointer;border:1px solid var(--sepia);border-radius:3px;padding:0.3rem;background:var(--paper);transition:all 0.2s;" onmouseover="this.style.background='var(--sepia)'" onmouseout="this.style.background='var(--paper)'">
          <div style="width:100%;height:120px;background-image:url('NYCZoning2026.jpg');background-size:cover;background-position:center;border-radius:2px;margin-bottom:0.3rem;"></div>
          <div style="font-family:'Source Code Pro',monospace;font-size:0.5rem;color:var(--ink);text-align:center;">2026 NYC Zoning</div>
        </div>
        
        <!-- 1879 Brumley Map Thumbnail -->
        <div onclick="selectSiteScene(3)" style="cursor:pointer;border:1px solid var(--sepia);border-radius:3px;padding:0.3rem;background:var(--paper);transition:all 0.2s;" onmouseover="this.style.background='var(--sepia)'" onmouseout="this.style.background='var(--paper)'">
          <div style="width:100%;height:120px;background-image:url('1879 Washington Square Park Bromley.jpg');background-size:cover;background-position:center;border-radius:2px;margin-bottom:0.3rem;"></div>
