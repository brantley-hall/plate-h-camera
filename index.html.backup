    </div>
    
    <!-- Occlusion Zone Controls -->
    <div style="display:flex;align-items:center;gap:0.5rem;margin-top:0.3rem;align-self:center;flex-wrap:wrap;justify-content:center;">
      <span style="font-size:0.6rem;color:var(--sepia);font-family:'Source Code Pro',monospace;">Occlusion</span>
      <input type="range" id="occlusionZone" min="0" max="100" value="0"
        style="width:120px;accent-color:var(--sepia);">
      <span style="font-size:0.6rem;color:var(--sepia);font-family:'Source Code Pro',monospace;min-width:28px;text-align:right;" id="occlusionZoneVal">0%</span>
    </div>
    <div class="plate-caption" id="plate-caption">—</div>            </div>
