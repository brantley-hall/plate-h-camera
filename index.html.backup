          <span style="color:var(--muted);">WDIST:</span> 
          <span style="color:var(--ink);font-weight:700;">${building.dimensions.width}</span> ft
          <span style="color:var(--muted);font-weight:700;">X</span>
          <span style="color:var(--muted);">NDIST:</span> 
          <span style="color:var(--ink);font-weight:700;">${building.dimensions.length}</span> ft
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.2rem;">
          <div><span style="color:var(--muted);">Height:</span> 
            <span style="color:var(--ink);font-weight:700;">${building.height}</span> ft
          </div>
          <div><span style="color:var(--muted);">Color:</span> <span style="display:inline-block;width:12px;height:12px;background:${building.color};border:1px solid var(--rule);vertical-align:middle;margin-right:4px;"></span>${building.color}</div>
          <div><span style="color:var(--muted);">Source:</span> user</div>
          <div><span style="color:var(--muted);">Type:</span> <span style="color:var(--sepia);font-weight:700;">Road (Read-only)</span></div>
        </div>
        ` : `
