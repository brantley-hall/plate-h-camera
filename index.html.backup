</div><!-- end workspace -->

<!--
MAP REPOSITIONING INSTRUCTIONS
===========================
Current map transformation values (locked):
- Scale: 1.41x
- Rotation: -4.0°
- X Offset: -1680px
- Y Offset: -2052px
- Opacity: 50%

To reposition the map for other photos:
1. Find the drawMap() function in the JavaScript section
2. Locate these transformation variables:
   - tempMapScale (currently 1.41)
   - tempMapRotation (currently -4.0)
   - tempMapX (currently -1680)
   - tempMapY (currently -2052)
   - tempMapOpacity (currently 50)
3. Adjust these values to align the map with new photo locations
4. The map image is loaded from: '1893KingsHandbook_map.png'
5. Use browser developer tools to debug positioning if needed

For reference, the map transformation uses canvas context:
ctx.translate(tempMapX, tempMapY);
ctx.rotate(tempMapRotation * Math.PI / 180);
ctx.scale(tempMapScale, tempMapScale);
-->


<!-- FULL-WIDTH SLIDER PANEL -->
<div class="slider-panel">
  <div class="slider-panel-inner" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
    
        
    <!-- Left Column: Camera Variable Settings -->
    <div>
      <div class="ctrl-section-title" style="font-size:0.7rem;text-align:center;margin-bottom:0.6rem;padding-bottom:0.4rem;border-bottom:1px solid var(--rule);">Camera Variable Settings</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">
        
        <!-- Camera Position Sub-Column -->
        <div>
          <div class="slider-group">
            <div class="ctrl-section-title">Camera Position</div>
            <div class="coord-display">Position: <span id="coords">—</span></div>
              <div class="sl">
              <label>Rotation</label>
              <input type="range" id="rotation" min="-180" max="180" value="0" step="0.1" style="flex:1;">
              <input type="number" id="rotation-input" min="-180" max="180" step="0.1" value="0" style="width:60px;font-size:0.6rem;margin-left:0.2rem;" onchange="updateRotationFromInput()">
              <span class="v" id="rot-out">0°</span>
            </div>
            
            <!-- X Position Input Only -->
            <div class="sl">
              <label>X (E–W)</label>
              <input type="number" id="camX-input" min="-400" max="400" step="1" value="-125" style="flex:1;padding:2px;font-size:0.6rem;" onchange="updateCameraFromInput()">
              <span class="v">ft</span>
            </div>
            
            <!-- Y Position Input Only -->
            <div class="sl">
              <label>Y (N–S)</label>
              <input type="number" id="camY-input" min="-400" max="400" step="1" value="0" style="flex:1;padding:2px;font-size:0.6rem;" onchange="updateCameraFromInput()">
              <span class="v">ft</span>
            </div>
            
                        <div class="sl"><label>Height</label><input type="range" id="cameraHeight" min="3" max="100" value="5" step="0.5"><span class="v" id="cameraHeight-out">5.0 ft</span></div>
          </div>
        </div>

        <!-- Camera Optics Sub-Column -->
        <div>
          <div class="slider-group">
            <div class="ctrl-section-title">Camera Optics</div>
            
            <!-- Mode Toggle -->
            <div class="sl" style="margin-bottom:0.8rem;">
              <label style="flex:0 0 100px;">Mode</label>
              <div style="display:flex;gap:8px;align-items:center;">
                <input type="radio" id="fov-mode" name="optics-mode" value="fov" checked>
                <label for="fov-mode" style="font-size:0.6rem;margin:0;">FOV</label>
                <input type="radio" id="camera-mode" name="optics-mode" value="camera">
                <label for="camera-mode" style="font-size:0.6rem;margin:0;">Camera Type</label>
              </div>
            </div>
            
            <!-- Focal Length Controls -->
            <div id="focal-controls" style="display:none;">
              <div class="sl"><label>Focal Length</label><input type="range" id="focal" min="0.2" max="25" value="8" step="0.1"><span class="v" id="focal-out">8 inches</span></div>
            </div>
            
            <!-- FOV Controls -->
            <div id="fov-controls" style="display:none;">
              <div class="sl"><label>Horizontal FOV</label><input type="range" id="fov-slider" min="5" max="120" value="15" step="1"><span class="v" id="fov-slider-out">15 degrees</span></div>
            </div>
            
            <!-- Camera Type Controls -->
            <div id="camera-controls">
              <div class="sl"><label>Lens Type</label>
                <select id="camera-type" style="flex:1;padding:2px;font-size:0.6rem;">
                  <option value="engraving">🎯 Human Vision (Engravings) - 60 degrees Natural View</option>
                  <option value="standard">35mm Equivalent - Standard FOV (45 degrees)</option>
                  <option value="telephoto">Telephoto Equivalent - Narrow FOV (7.5 degrees)</option>
                  <option value="wide" selected>Wide Angle Equivalent - Wide FOV (70 degrees)</option>
                  <option value="fisheye">Fisheye Equivalent - Ultra Wide (120 degrees)</option>
                </select>
              </div>
              <div class="sl"><label>Lens FOV</label><span style="flex:1"></span><span class="v" id="camera-fov-out">70 degrees</span></div>
              <div class="sl"><label>Plate Focal</label><span style="flex:1"></span><span class="v" id="camera-focal-out">8 inches</span></div>
            </div>
            
            <!-- Display Values (always shown) -->
            <div class="sl"><label>Horizontal FOV</label><span style="flex:1"></span><span class="v" id="fov-out">15 degrees</span></div>
            <div class="sl"><label>Vertical FOV</label><span style="flex:1"></span><span class="v" id="vfov-out">20.9 degrees</span></div>
            
                        
                      </div>
        </div>
      </div>
    </div>
    
    <!-- Right Column: Building Settings -->
    <div>
      <div class="ctrl-section-title" style="font-size:0.7rem;text-align:center;margin-bottom:0.6rem;padding-bottom:0.4rem;border-bottom:1px solid var(--rule);">Building Settings</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">
        
        <!-- NYU & Row Houses Sub-Column -->
        <div>
          <!-- NYU Building -->
          <div class="slider-group">
            <div class="ctrl-section-title">NYU</div>
            <div class="sl"><label>Position</label><input type="range" id="nyuslide" min="-70" max="70" value="10" step="1" style="width:30px;"><span class="v" id="nyu-out">10</span></div>
            <div class="sl"><label>Height</label><input type="range" id="nyuheight" min="10" max="120" value="85" step="1" style="width:30px;"><span class="v" id="nyuheight-out">85</span></div>
          </div>

          <!-- Row Houses -->
          <div class="slider-group">
            <div class="ctrl-section-title">Row Houses</div>
            <div class="sl"><label>Position RH1</label><input type="range" id="rh1slide" min="0" max="100" value="10" step="1" style="width:30px;"><span class="v" id="rh1-out">10</span></div>
            <div class="sl"><label>Height RH1</label><input type="range" id="rh1height" min="10" max="120" value="45" step="1" style="width:30px;"><span class="v" id="rh1height-out">45</span></div>
            <div class="sl"><label>Position RH2</label><input type="range" id="rh2slide" min="0" max="100" value="10" step="1" style="width:30px;"><span class="v" id="rh2-out">10</span></div>
            <div class="sl"><label>Height RH2</label><input type="range" id="rh2height" min="10" max="120" value="45" step="1" style="width:30px;"><span class="v" id="rh2height-out">45</span></div>
          </div>
        </div>

        <!-- Church Sub-Column -->
        <div>
          <div class="slider-group">
            <div class="ctrl-section-title">Church</div>
            <div class="sl"><label>Distance</label><input type="range" id="churchdist" min="700" max="900" value="777" step="10" style="width:30px;"><span class="v" id="churchdist-out">777</span></div>
            <div class="sl"><label>Position</label><input type="range" id="churchslide" min="0" max="100" value="0" step="1" style="width:30px;"><span class="v" id="church-out">0</span></div>
            <div class="sl"><label>North Height</label><input type="range" id="chnheight" min="10" max="120" value="50" step="1" style="width:30px;"><span class="v" id="chnheight-out">50</span></div>
            <div class="sl"><label>Ctr Height</label><input type="range" id="chmheight" min="10" max="120" value="90" step="1" style="width:30px;"><span class="v" id="chmheight-out">90</span></div>
            <div class="sl"><label>South Height</label><input type="range" id="chsheight" min="10" max="120" value="50" step="1" style="width:30px;"><span class="v" id="chsheight-out">50</span></div>
          </div>
        </div>
      </div>
    </div>
    
  </div>
</div>


<!-- hidden stubs for legacy JS refs -->
<span style="display:none" id="zoom-coord"></span>
<span style="display:none" id="ps-pos"></span>
