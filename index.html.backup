<!-- Hidden RH1 and RH2 sliders - moved here to preserve JS dependencies -->
<div style="display:none; position:absolute; left:-9999px; top:-9999px;">
  <div class="sl"><label>RH1 position</label><input type="range" id="rh1slide" min="0" max="100" value="10" step="1"><span class="v" id="rh1-out">10 ft</span></div>
  <div class="sl"><label>RH1 height</label><input type="range" id="rh1height" min="10" max="120" value="45" step="1"><span class="v" id="rh1height-out">45 ft</span></div>
  <div class="sl"><label>RH2 position</label><input type="range" id="rh2slide" min="0" max="100" value="10" step="1"><span class="v" id="rh2-out">10 ft</span></div>
  <div class="sl"><label>RH2 height</label><input type="range" id="rh2height" min="10" max="120" value="45" step="1"><span class="v" id="rh2height-out">45 ft</span></div>
</div>

<span style="display:none" id="ps-rh1"></span>
<span style="display:none" id="ps-rh2"></span>
<span style="display:none" id="ps-sky"></span>
