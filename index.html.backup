// Simple map switching
function switchMap(index) {
  const config = MAP_CONFIGS[index];
  if (!config) return;
  
  // Update current map
  currentMapIndex = parseInt(index);
  
  // Update UI
  const selector = document.getElementById('map-selector');
  if (selector) selector.value = index;
  
  const nameSpan = document.getElementById('current-map-name');
  if (nameSpan) nameSpan.textContent = config.name;
  
  // Load map image for canvas
  const mapImg = new Image();
  mapImg.onload = () => {
    _mapImg = mapImg; // Set global map image
    loadMapSettings();
    drawAll();
  };
  mapImg.onerror = () => {
    console.error('Failed to load map:', config.filename);
  };
  mapImg.src = config.filename;
}

